@jsr:registry=https://npm.jsr.io

# Private registry for @dididecks/shell, published as
# @lossless-group/dididecks-shell and consumed via an `npm:` alias in
# package.json (see dependencies). Needs a GITHUB_TOKEN (or NPM_AUTH_TOKEN)
# env var with `read:packages` scope — set as a Vercel project env var.
@lossless-group:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}

# pnpm settings for reach-edu-hub. Applies when pnpm runs from inside this
# directory directly — most importantly on Vercel, which deploys this repo
# standalone with no access to the parent dididecks-ai pseudomonorepo.

# Treat this project as standalone — do not try to discover or use the parent
# dididecks-ai workspace. Critical for Vercel. @dididecks/shell now resolves
# from the private registry above, not workspace linking, so this is safe
# both locally and on Vercel.
ignore-workspace=true

# Hoist dependencies into a flat node_modules so packages that expect a classic
# layout (Vite/Rollup/Astro plugins) work.
shamefully-hoist=true

# Auto-install peer dependencies.
auto-install-peers=true

# Don't fail builds on peer-dependency mismatches.
strict-peer-dependencies=false

# Allow lifecycle scripts (some build tooling needs them).
enable-pre-post-scripts=true
ignore-scripts=false
