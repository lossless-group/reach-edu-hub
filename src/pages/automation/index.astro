---
/**
 * Pipeline Building & Automation — scroll deck.
 *
 * Companion deck to /story. Where /story is the Reach narrative, this deck
 * is the Lossless side of the work — what we'll build for Reach next.
 *
 * Phase 1 of the deck-iteration-workflow skill: single-page scroll deck,
 * Tailwind built-in tokens only, no var(--theme-*) references. Mode-aware
 * via the dark: and vibrant: custom variants wired in src/styles/global.css.
 *
 * Source outline: context-v/narratives/pipeline-building-automation.md
 */
import '../../styles/global.css';
import Header from '../../components/basics/Header.astro';
import MetaTags from '../../components/basics/MetaTags.astro';
import PageAsDeckWrapper from '../../layouts/PageAsDeckWrapper.astro';
import { SCROLL_DECK_SEO } from '../../lib/seo';

const seo = SCROLL_DECK_SEO['/automation']!;

import T01FirstThingsFirst       from '../../layouts/sections/automation/T01-FirstThingsFirst.astro';
import T02ThreeGamesOnePipeline  from '../../layouts/sections/automation/T02-ThreeGamesOnePipeline.astro';
import T03FiveLevers             from '../../layouts/sections/automation/T03-FiveLevers.astro';
import T04KeyPlayers             from '../../layouts/sections/automation/T04-KeyPlayers.astro';
import T05DonorPersonalization   from '../../layouts/sections/automation/T05-DonorPersonalization.astro';
import T06GrantPipeline          from '../../layouts/sections/automation/T06-GrantPipeline.astro';
import T07ProbableStack          from '../../layouts/sections/automation/T07-ProbableStack.astro';
import T08DataSources            from '../../layouts/sections/automation/T08-DataSources.astro';
import T09NewIdentification      from '../../layouts/sections/automation/T09-NewIdentification.astro';
import T10GeographicClusters     from '../../layouts/sections/automation/T10-GeographicClusters.astro';
import T11ThemeMapping           from '../../layouts/sections/automation/T11-ThemeMapping.astro';
---

<!doctype html>
<html lang="en" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/reach-favicon.png" />

    <MetaTags title={seo.title} description={seo.description} ogImage={seo.ogImage} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('mode');
          var valid = ['light', 'dark', 'vibrant'];
          var sysLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
          var mode = valid.indexOf(stored) !== -1 ? stored : (sysLight ? 'light' : 'dark');
          var html = document.documentElement;
          html.setAttribute('data-mode', mode);
          if (mode === 'dark' || mode === 'vibrant') {
            html.classList.add('dark');
          } else {
            html.classList.remove('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-stone-50 text-slate-900 antialiased" style="--deck-height: calc(100vh - 3rem);">
    <Header />

    <PageAsDeckWrapper enableScrollSnap={true} showNavigationHints={true}>
      <T01FirstThingsFirst />
      <T02ThreeGamesOnePipeline />
      <T03FiveLevers />
      <T04KeyPlayers />
      <T05DonorPersonalization />
      <T06GrantPipeline />
      <T07ProbableStack />
      <T08DataSources />
      <T09NewIdentification />
      <T10GeographicClusters />
      <T11ThemeMapping />
    </PageAsDeckWrapper>

    <script>
      import '../../utils/mode-switcher.js';
    </script>
  </body>
</html>
