---
/**
 * /scroll/story/editorial/ — The Reach Story, v2 editorial / serif treatment.
 *
 * Deck "story", variant "editorial". Same nine sections as baseline, serif-
 * driven editorial styling. Migrated onto @dididecks/shell on 2026-06-29
 * (was /story/version-2) — see
 * context-v/plans/Integrate-Reach-Edu-Hub-into-Dididecks-Shell.md.
 */
import '../../../../styles/global.css';
import Header from '../../../../components/basics/Header.astro';
import MetaTags from '../../../../components/basics/MetaTags.astro';
import PageAsDeckWrapper from '../../../../layouts/PageAsDeckWrapper.astro';
import DeckOverlayScrollUI from '@dididecks/shell/components/DeckOverlay--Scroll-UI.astro';
import { SCROLL_DECK_SEO } from '../../../../lib/seo';

const seo = SCROLL_DECK_SEO['/scroll/story/editorial']!;

import T01ApprenticeshipDegree from '../../../../layouts/sections/story/version-2/T01-ApprenticeshipDegree.astro';
import T02EquityMission        from '../../../../layouts/sections/story/version-2/T02-EquityMission.astro';
import T03ReachMethod          from '../../../../layouts/sections/story/version-2/T03-ReachMethod.astro';
import T04Affordability        from '../../../../layouts/sections/story/version-2/T04-Affordability.astro';
import T05Faculty              from '../../../../layouts/sections/story/version-2/T05-Faculty.astro';
import T06TeacherPipeline      from '../../../../layouts/sections/story/version-2/T06-TeacherPipeline.astro';
import T07Partnerships         from '../../../../layouts/sections/story/version-2/T07-Partnerships.astro';
import T08ScaleTraction        from '../../../../layouts/sections/story/version-2/T08-ScaleTraction.astro';
import T09Healthcare           from '../../../../layouts/sections/story/version-2/T09-Healthcare.astro';
---

<!doctype html>
<html lang="en" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/reach-favicon.png" />

    <MetaTags title={seo.title} description={seo.description} ogImage={seo.ogImage} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('mode');
          var valid = ['light', 'dark', 'vibrant'];
          var sysLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
          var mode = valid.indexOf(stored) !== -1 ? stored : (sysLight ? 'light' : 'dark');
          var html = document.documentElement;
          html.setAttribute('data-mode', mode);
          if (mode === 'dark' || mode === 'vibrant') html.classList.add('dark');
          else html.classList.remove('dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-white text-slate-900 antialiased" style="--deck-height: calc(100vh - 3rem);">
    <Header />

    <PageAsDeckWrapper enableScrollSnap={true} showNavigationHints={true}>
      <T01ApprenticeshipDegree />
      <T02EquityMission />
      <T03ReachMethod />
      <T04Affordability />
      <T05Faculty />
      <T06TeacherPipeline />
      <T07Partnerships />
      <T08ScaleTraction />
      <T09Healthcare />
    </PageAsDeckWrapper>

    <DeckOverlayScrollUI deckSlug="story" variantSlug="editorial" />

    <script>
      import '../../../../utils/mode-switcher.js';
    </script>
  </body>
</html>
