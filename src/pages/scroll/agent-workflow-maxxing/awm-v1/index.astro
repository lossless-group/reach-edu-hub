---
/**
 * /scroll/agent-workflow-maxxing/awm-v1/ — "Agent Workflow Maxxing"
 *
 * Fourth strategy deck in the `strategies` collection — operating doctrine for a
 * small team. Scroll-UI, v1 draft.
 * Narrative source: context-v/narratives/strategies/agent-workflow-maxxing/README.md
 *
 * Token-driven via deck-primitives.css (light/dark/vibrant). Figures marked
 * <span class="deck-verify"> are unverified vendor/anecdote values.
 */
import '../../../../styles/global.css';
import '../../../../styles/theme.css';
import '../../../../styles/deck-primitives.css';
import Header from '../../../../components/basics/Header.astro';
import MetaTags from '../../../../components/basics/MetaTags.astro';
import PageAsDeckWrapper from '../../../../layouts/PageAsDeckWrapper.astro';
import DeckOverlayScrollUI from '@dididecks/shell/components/DeckOverlay--Scroll-UI.astro';
import { SCROLL_DECK_SEO } from '../../../../lib/seo';

const seo = SCROLL_DECK_SEO['/scroll/agent-workflow-maxxing/awm-v1']!;

import T01Cover          from '../../../../layouts/sections/agent-workflow-maxxing/T01-Cover.astro';
import T02Bottleneck     from '../../../../layouts/sections/agent-workflow-maxxing/T02-Bottleneck.astro';
import T03TheShift       from '../../../../layouts/sections/agent-workflow-maxxing/T03-TheShift.astro';
import T04ABM            from '../../../../layouts/sections/agent-workflow-maxxing/T04-ABM.astro';
import T05Travel         from '../../../../layouts/sections/agent-workflow-maxxing/T05-Travel.astro';
import T06Events         from '../../../../layouts/sections/agent-workflow-maxxing/T06-Events.astro';
import T07Grants         from '../../../../layouts/sections/agent-workflow-maxxing/T07-Grants.astro';
import T08Social         from '../../../../layouts/sections/agent-workflow-maxxing/T08-Social.astro';
import T09BestPractices  from '../../../../layouts/sections/agent-workflow-maxxing/T09-BestPractices.astro';
import T10ToolingMap     from '../../../../layouts/sections/agent-workflow-maxxing/T10-ToolingMap.astro';
import T11Payoff         from '../../../../layouts/sections/agent-workflow-maxxing/T11-Payoff.astro';
---

<!doctype html>
<html lang="en" class="theme-default" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/reach-favicon.png" />

    <MetaTags title={seo.title} description={seo.description} ogImage={seo.ogImage} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('mode');
          var valid = ['light', 'dark', 'vibrant'];
          var sysLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
          var mode = valid.indexOf(stored) !== -1 ? stored : (sysLight ? 'light' : 'dark');
          var html = document.documentElement;
          html.setAttribute('data-mode', mode);
          if (mode === 'dark' || mode === 'vibrant') html.classList.add('dark');
          else html.classList.remove('dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="font-sans" style="--deck-height: calc(100vh - 3rem);">
    <Header />

    <PageAsDeckWrapper enableScrollSnap={true} showNavigationHints={true}>
      <T01Cover />
      <T02Bottleneck />
      <T03TheShift />
      <T04ABM />
      <T05Travel />
      <T06Events />
      <T07Grants />
      <T08Social />
      <T09BestPractices />
      <T10ToolingMap />
      <T11Payoff />
    </PageAsDeckWrapper>

    <DeckOverlayScrollUI deckSlug="agent-workflow-maxxing" variantSlug="awm-v1" />

    <script>
      import '../../../../utils/mode-switcher.js';
    </script>
  </body>
</html>
