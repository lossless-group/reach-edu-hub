---
/**
 * Changelog detail — render one entry's full body via @lossless-group/lfm.
 *
 * Pattern adapted from sites/calmstorm-decks/src/pages/changelog/[slug].astro,
 * retokenized for reach-edu-hub's editorial aesthetic. Body is parsed through
 * LFM's parseMarkdown() and rendered through src/components/markdown/AstroMarkdown.
 */
import BaseThemeLayout from '../../layouts/BaseThemeLayout.astro';
import AstroMarkdown from '../../components/markdown/AstroMarkdown.astro';
import { getCollection } from 'astro:content';
import { parseMarkdown } from '@lossless-group/lfm';

export async function getStaticPaths() {
  const entries = await getCollection('changelog', ({ data }) => data.publish === true);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const fm = entry.data;
const tree = await parseMarkdown(entry.body);

// Sort all entries newest-first, find prev/next neighbors for the bottom nav.
const all = (await getCollection('changelog', ({ data }) => data.publish === true)).sort(
  (a, b) =>
    b.data.date_authored_initial_draft.getTime() -
    a.data.date_authored_initial_draft.getTime(),
);
const idx = all.findIndex((e) => e.id === entry.id);
const newer = idx > 0 ? all[idx - 1] : undefined;
const older = idx < all.length - 1 ? all[idx + 1] : undefined;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseThemeLayout
  title={`${fm.title} · Changelog`}
  description={fm.lede}
  ogType="article"
  publishedTime={fm.date_authored_initial_draft.toISOString()}
  modifiedTime={(fm.date_last_updated ?? fm.date_authored_current_draft ?? fm.date_authored_initial_draft).toISOString()}
  author={fm.authors[0]}
  tags={fm.tags}
>
  <article class="px-8 md:px-16 lg:px-24 py-16 md:py-20 bg-white dark:bg-slate-950 vibrant:bg-indigo-950">
    <div class="mx-auto md:max-w-[70vw]">
      <a
        href="/changelog"
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400 vibrant:text-cyan-300 hover:text-orange-500 no-underline transition-colors mb-10"
      >
        <span aria-hidden="true">←</span> All changelogs
      </a>

      <header class="border-b border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/30 pb-8 mb-10">
        <p class="flex items-baseline gap-3 flex-wrap mb-6">
          <time
            class="font-mono text-xs uppercase tracking-[0.2em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 tabular-nums"
            datetime={fm.date_authored_initial_draft.toISOString().slice(0, 10)}
          >
            {fmtDate(fm.date_authored_initial_draft)}
          </time>
          {fm.at_semantic_version && (
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/70">
              v{fm.at_semantic_version}
            </span>
          )}
          {fm.category && (
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-orange-500">
              {fm.category}
            </span>
          )}
        </p>

        <h1 class="font-serif text-4xl md:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight mb-6">
          {fm.title}
        </h1>

        <p class="font-serif italic text-lg md:text-xl text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed mb-8">
          {fm.lede}
        </p>

        <div class="flex flex-col gap-2 text-xs">
          {fm.authors.length > 0 && (
            <p class="flex items-baseline gap-2 flex-wrap">
              <span class="font-mono uppercase tracking-[0.25em] text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/70">Authors</span>
              <span class="font-serif text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85">{fm.authors.join(' · ')}</span>
              {fm.augmented_with && (
                <span class="font-serif italic text-slate-500 dark:text-slate-400 vibrant:text-cyan-300/85">w/ {fm.augmented_with}</span>
              )}
            </p>
          )}
          {fm.tags.length > 0 && (
            <p class="flex items-baseline gap-2 flex-wrap">
              <span class="font-mono uppercase tracking-[0.25em] text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/70">Tags</span>
              <span class="flex flex-wrap gap-x-2 gap-y-1">
                {fm.tags.map((t) => (
                  <span class="font-mono text-slate-600 dark:text-slate-400 vibrant:text-cyan-300/85">#{t}</span>
                ))}
              </span>
            </p>
          )}
        </div>
      </header>

      <div class="prose-changelog">
        <AstroMarkdown node={tree} />
      </div>

      <nav class="mt-16 grid grid-cols-2 gap-6 border-t border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/30 pt-8 text-xs">
        <div>
          {older && (
            <a
              href={`/changelog/${older.id}`}
              class="block no-underline group hover:text-orange-500"
            >
              <span class="block font-mono uppercase tracking-[0.25em] text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/70 mb-1">← Older</span>
              <span class="block font-serif text-base text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-snug group-hover:text-orange-500 transition-colors">
                {older.data.title}
              </span>
              <span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400 vibrant:text-cyan-300/70 mt-1 tabular-nums">
                {fmtDate(older.data.date_authored_initial_draft)}
              </span>
            </a>
          )}
        </div>
        <div class="text-right">
          {newer && (
            <a
              href={`/changelog/${newer.id}`}
              class="block no-underline group hover:text-orange-500"
            >
              <span class="block font-mono uppercase tracking-[0.25em] text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/70 mb-1">Newer →</span>
              <span class="block font-serif text-base text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-snug group-hover:text-orange-500 transition-colors">
                {newer.data.title}
              </span>
              <span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400 vibrant:text-cyan-300/70 mt-1 tabular-nums">
                {fmtDate(newer.data.date_authored_initial_draft)}
              </span>
            </a>
          )}
        </div>
      </nav>
    </div>
  </article>

  <style is:global>
    /* Article prose for the changelog body, rendered through @lossless-group/lfm.
       Editorial / serif treatment with orange accent. Mode-aware via CSS vars. */
    .prose-changelog {
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 0.98rem;
      line-height: 1.7;
      max-width: 44rem;
    }
    .prose-changelog > * + * { margin-top: 1.1rem; }
    .prose-changelog h1 { display: none; } /* page header already shows the title */
    .prose-changelog h2 {
      font-family: var(--font-heading, ui-serif, Georgia, serif);
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--color-text);
      line-height: 1.2;
      margin: 2.5rem 0 1rem 0;
      padding-top: 1rem;
      border-top: 1px solid var(--color-border);
    }
    .prose-changelog h3 {
      font-family: var(--font-heading, ui-serif, Georgia, serif);
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--color-text);
      margin: 1.75rem 0 0.5rem 0;
    }
    .prose-changelog h4 {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--color-text);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin: 1.5rem 0 0.4rem 0;
    }
    .prose-changelog p { margin: 0 0 1rem 0; }
    .prose-changelog p:last-child { margin-bottom: 0; }
    .prose-changelog strong { color: var(--color-text); font-weight: 600; }
    .prose-changelog em { font-style: italic; }
    .prose-changelog a {
      color: #ff8300; /* orange-saccharine */
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .prose-changelog a:hover { opacity: 0.8; }
    .prose-changelog ul,
    .prose-changelog ol { margin: 0 0 1rem 1.5rem; padding: 0; }
    .prose-changelog ul { list-style: disc; }
    .prose-changelog ol { list-style: decimal; }
    .prose-changelog li { margin: 0 0 0.35rem 0; color: var(--color-text-muted); }
    .prose-changelog li ul,
    .prose-changelog li ol { margin-top: 0.35rem; }
    .prose-changelog code {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.85em;
      background: color-mix(in srgb, var(--color-border) 40%, transparent);
      border-radius: 3px;
      padding: 0.1em 0.4em;
      color: var(--color-text);
    }
    .prose-changelog pre {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.85em;
      background: color-mix(in srgb, var(--color-surface) 60%, var(--color-background));
      border: 1px solid var(--color-border);
      border-radius: 0.25rem;
      padding: 1rem;
      overflow-x: auto;
      margin: 1.25rem 0;
    }
    .prose-changelog pre code {
      background: transparent;
      padding: 0;
    }
    .prose-changelog blockquote {
      border-left: 3px solid #ff8300;
      margin: 1.25rem 0;
      padding: 0.25rem 0 0.25rem 1rem;
      color: var(--color-text-muted);
      font-style: italic;
    }
    .prose-changelog hr {
      border: 0;
      border-top: 1px solid var(--color-border);
      margin: 2rem 0;
    }
    .prose-changelog table {
      width: 100%;
      font-size: 0.88rem;
      border-collapse: collapse;
      margin: 1.25rem 0;
    }
    .prose-changelog th,
    .prose-changelog td {
      text-align: left;
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid var(--color-border);
      vertical-align: top;
    }
    .prose-changelog th {
      font-weight: 600;
      color: var(--color-text);
      border-bottom: 1px solid var(--color-text-muted);
      background: color-mix(in srgb, var(--color-surface) 50%, transparent);
    }
    .prose-changelog del { color: var(--color-text-muted); opacity: 0.6; }
  </style>
</BaseThemeLayout>
