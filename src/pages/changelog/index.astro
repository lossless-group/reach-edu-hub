---
/**
 * Changelog index — list every published entry from the `changelog`
 * content collection as a card. Click-through to /changelog/[slug] for
 * the full body rendered via @lossless-group/lfm.
 *
 * Pattern adapted from sites/calmstorm-decks/src/pages/changelog/index.astro,
 * retokenized for reach-edu-hub's editorial / serif aesthetic.
 */
import BaseThemeLayout from '../../layouts/BaseThemeLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('changelog', ({ data }) => data.publish === true);

const entries = all.sort(
  (a, b) =>
    b.data.date_authored_initial_draft.getTime() -
    a.data.date_authored_initial_draft.getTime(),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseThemeLayout
  title="Changelog · Reach goes Lossless"
  description="Build notes from the Reach × Lossless hub — newest first. What shipped, why it matters, what it enables next."
>
  <section class="px-8 md:px-16 lg:px-24 py-20 md:py-28 bg-white dark:bg-slate-950 vibrant:bg-indigo-950">
    <div class="mx-auto md:max-w-[70vw]">
      <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-6">
        Notebook
      </p>
      <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight max-w-4xl mb-6">
        Changelog.
      </h1>
      <p class="font-serif italic text-lg md:text-xl text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 max-w-3xl leading-relaxed">
        Build notes from the Reach <span class="not-italic text-orange-500">×</span> Lossless hub. Newest first.
      </p>
    </div>
  </section>

  <section class="px-8 md:px-16 lg:px-24 py-16 md:py-20 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black border-y border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/30">
    <div class="mx-auto md:max-w-[70vw]">
      {entries.length === 0 && (
        <p class="font-serif italic text-lg text-slate-600 dark:text-slate-400 vibrant:text-cyan-300/85">
          No published entries yet.
        </p>
      )}

      <ol class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {entries.map((entry) => {
          const fm = entry.data;
          return (
            <li>
              <a
                href={`/changelog/${entry.id}`}
                class="group block h-full border border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/40 bg-white dark:bg-slate-950 vibrant:bg-indigo-950/40 p-6 md:p-7 rounded-sm hover:border-orange-500 dark:hover:border-orange-500 vibrant:hover:border-orange-500 transition-colors no-underline"
              >
                <header class="flex items-baseline gap-3 flex-wrap mb-4">
                  <time
                    class="font-mono text-xs uppercase tracking-[0.2em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 tabular-nums"
                    datetime={fm.date_authored_initial_draft.toISOString().slice(0, 10)}
                  >
                    {fmtDate(fm.date_authored_initial_draft)}
                  </time>
                  {fm.at_semantic_version && (
                    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/70">
                      v{fm.at_semantic_version}
                    </span>
                  )}
                  {fm.category && (
                    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-orange-500">
                      {fm.category}
                    </span>
                  )}
                </header>

                <h2 class="font-serif text-2xl md:text-3xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-snug tracking-tight mb-4 group-hover:text-orange-500 transition-colors">
                  {fm.title}
                </h2>

                <p class="font-serif italic text-base text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed mb-6">
                  {fm.lede}
                </p>

                {fm.tags.length > 0 && (
                  <p class="flex flex-wrap gap-x-3 gap-y-1 mb-6">
                    {fm.tags.map((t) => (
                      <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-slate-500 dark:text-slate-400 vibrant:text-cyan-300/80">
                        #{t}
                      </span>
                    ))}
                  </p>
                )}

                <p class="font-mono text-xs uppercase tracking-[0.2em] text-orange-500 group-hover:translate-x-1 transition-transform inline-block">
                  Read full entry →
                </p>
              </a>
            </li>
          );
        })}
      </ol>
    </div>
  </section>
</BaseThemeLayout>
