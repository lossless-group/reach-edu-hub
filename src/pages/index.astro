---
/**
 * Reach Education Hub — Home (`/`).
 *
 * Sitemap doc: context-v/sitemap/Page__Index.md
 *
 * Audience: Reach University senior executives. Already love us — we're wowing,
 * not selling. Page is the hub's friendly front door.
 *
 * Style rules: inline Tailwind utilities, built-in tokens only, mode-aware
 * via dark: and vibrant: variants. Editorial / serif aesthetic to match the
 * v2 deck. No central CTA per the brief.
 */
import BaseThemeLayout from '../layouts/BaseThemeLayout.astro';
---

<BaseThemeLayout
  title="Reach Education Hub"
  description="Booting up systems for Lossless Collaboration. A working hub for Reach University × The Lossless Group."
>
  <!-- Hero -->
  <section class="px-8 md:px-16 lg:px-24 py-24 md:py-32 bg-white dark:bg-slate-950 vibrant:bg-indigo-950">
    <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-10">
      Reach University <span class="text-orange-500">×</span> The Lossless Group
    </p>

    <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.04] tracking-tight max-w-5xl">
      Booting up systems for <em class="not-italic text-orange-500">Lossless Collaboration.</em>
    </h1>

    <p class="mt-12 max-w-2xl font-serif italic text-xl md:text-2xl text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed">
      A working hub for the partnership — presentation design iterations for the current fundraise, and the systems we're booting up next.
    </p>
  </section>

  <!-- Two pillars -->
  <section class="px-8 md:px-16 lg:px-24 py-20 md:py-28 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black border-y border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/30">
    <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-12 md:mb-16">
      What we're working on together
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 max-w-7xl">
      <!-- Pillar 01 -->
      <div>
        <p class="font-mono text-xs text-orange-500 mb-4">01</p>
        <h2 class="font-serif text-4xl md:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.04] tracking-tight mb-2">
          Raise Better.
        </h2>
        <p class="font-serif italic text-base md:text-lg text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-8 tracking-wide">
          Fundraise Acceleration
        </p>
        <p class="font-serif text-lg text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed mb-8">
          Unlock breakthroughs in philanthropic fundraising — through:
        </p>
        <ul class="space-y-3 text-base text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-snug">
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Materials generation</strong> — decks, briefs, narratives, one-pagers.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Process improvements</strong> — how the fundraise actually runs week to week.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Talent &amp; team building</strong> — roles, hires, structures.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Strategic presence &amp; connections</strong> — convenings, outreach, relationship architecture.</span>
          </li>
        </ul>
      </div>

      <!-- Pillar 02 -->
      <div>
        <p class="font-mono text-xs text-orange-500 mb-4">02</p>
        <h2 class="font-serif text-4xl md:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.04] tracking-tight mb-2">
          Build Smarter.
        </h2>
        <p class="font-serif italic text-base md:text-lg text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-8 tracking-wide">
          Agentic Leapfrog
        </p>
        <p class="font-serif text-lg text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed mb-8">
          Leapfrog legacy tech, vendor lock-in, siloed solutions — fast-forward into the Agentic AI era through:
        </p>
        <ul class="space-y-3 text-base text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-snug">
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Data preparation</strong> — getting institutional data ready to feed agents.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">System interoperability</strong> — making siloed tools talk.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Precision custom design &amp; development</strong> — bespoke where bespoke wins.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Best-in-class thinking</strong> — what's good, why, and what matters.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-orange-500 font-serif text-xl leading-none mt-0.5">·</span>
            <span><strong class="font-medium text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">Procurement, adoption, training, &amp; use</strong> — the human side of any new system.</span>
          </li>
        </ul>
      </div>
    </div>

    <p class="mt-16 max-w-3xl font-serif italic text-lg text-slate-600 dark:text-slate-400 vibrant:text-cyan-300 border-l-2 border-orange-500 pl-5">
      The bet — most institutions are choosing between vendor lock-in and DIY pain. There's a third path.
    </p>
  </section>

  <!-- Where this is, where it's going -->
  <section class="px-8 md:px-16 lg:px-24 py-20 md:py-28 bg-white dark:bg-slate-950 vibrant:bg-indigo-950">
    <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-8">
      Where the hub is now · where it's going
    </p>

    <h2 class="font-serif text-3xl md:text-5xl lg:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight max-w-5xl mb-16">
      Right now, we're <em class="not-italic text-orange-500">iterating presentations</em> for the fundraise.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12 max-w-6xl">
      <div class="border-t-2 border-orange-500 pt-6">
        <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-3">Where this might go · A</p>
        <p class="font-serif text-lg md:text-xl text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed">
          <strong class="not-italic text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 font-medium">Market leadership content</strong> — reports and Agent-harnessed materials generation.
        </p>
      </div>
      <div class="border-t-2 border-orange-500 pt-6">
        <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-3">Where this might go · B</p>
        <p class="font-serif text-lg md:text-xl text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed">
          <strong class="not-italic text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 font-medium">Agent-harnessed donor &amp; sponsor targeting</strong> — using frontier techniques.
        </p>
      </div>
      <div class="border-t-2 border-orange-500 pt-6">
        <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-3">Where this might go · C</p>
        <p class="font-serif text-lg md:text-xl text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed">
          <strong class="not-italic text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 font-medium">Precision upgrades in ops or teaching &amp; learning</strong> — cutting-edge solutions where they earn their place.
        </p>
      </div>
    </div>
  </section>

  <!-- Click around -->
  <section class="px-8 md:px-16 lg:px-24 py-20 md:py-28 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black border-y border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/30">
    <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-4">Click around</p>

    <h2 class="font-serif text-3xl md:text-5xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight max-w-3xl mb-12">
      Agent-harnessed slide generation &amp; decks.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl">
      <a
        href="/story"
        class="group block border border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/40 bg-white dark:bg-slate-950 vibrant:bg-indigo-950/40 p-7 rounded-sm hover:border-orange-500 dark:hover:border-orange-500 vibrant:hover:border-orange-500 transition-colors no-underline"
      >
        <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-4">
          Tool · in use
        </p>
        <h3 class="font-serif text-2xl md:text-3xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 mb-3 group-hover:text-orange-500 transition-colors">
          Deck-o-Knots
        </h3>
        <p class="font-serif italic text-base text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed mb-8">
          A homegrown deck-ideas and slides generator — with a presentation suite to boot.
        </p>
        <p class="font-mono text-xs uppercase tracking-widest text-orange-500 group-hover:translate-x-1 transition-transform inline-block">
          See the live deck →
        </p>
      </a>
    </div>

    <p class="mt-10 font-serif italic text-sm text-slate-500 dark:text-slate-400 vibrant:text-cyan-300/70 max-w-2xl">
      More cards land here as the work ships.
    </p>
  </section>

  <!-- Friendly nod / contact -->
  <section class="px-8 md:px-16 lg:px-24 py-20 md:py-24 bg-white dark:bg-slate-950 vibrant:bg-indigo-950">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-6">
        Friendly nod
      </p>
      <p class="font-serif text-xl md:text-3xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-snug">
        You've got my number. <em class="not-italic text-orange-500">Text or WhatsApp beats email</em> — I don't really check email.
      </p>
      <p class="mt-6 font-serif italic text-base text-slate-600 dark:text-slate-400 vibrant:text-cyan-300/85">
        — Michael Staton, single point of contact for the Lossless Group <span class="text-orange-500">×</span> Reach University collaboration.
      </p>
    </div>
  </section>
</BaseThemeLayout>
