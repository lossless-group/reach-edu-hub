---
import BoilerPlateHTML from './BoilerPlateHTML.astro';
import Header from '../components/basics/Header.astro';
import Footer from '../components/basics/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  themeClass?: string;
  /** OG image override — path under /public or absolute URL. */
  ogImage?: string;
  ogImageAlt?: string;
  /** "website" (default), "article", etc. */
  ogType?: string;
  /** Defaults to false — the hub is public. Set true for internal/private pages. */
  noindex?: boolean;
  /** Article-only fields, emitted only when ogType === "article". */
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
}

const {
  title = 'Reach goes Lossless',
  description = 'A working hub for Reach University × The Lossless Group.',
  themeClass = 'theme-default',
  ogImage,
  ogImageAlt,
  ogType,
  noindex,
  publishedTime,
  modifiedTime,
  author,
  tags,
} = Astro.props;
---

<BoilerPlateHTML
  title={title}
  description={description}
  themeClass={themeClass}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  ogType={ogType}
  noindex={noindex}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  author={author}
  tags={tags}
>
  <div class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </div>

  <script>
    import '../utils/theme-switcher.js';
    import '../utils/mode-switcher.js';
  </script>
</BoilerPlateHTML>
