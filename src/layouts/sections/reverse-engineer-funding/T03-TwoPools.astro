---
/**
 * Slide 03 · Two Concentrated Pools — where the grant money actually sits.
 * Contrast layout: mega-foundations vs. new-money UHNWIs.
 * Figures verified against primary sources 2026-07-06 (see citationDefs).
 */
import { buildCitationIndex, citationsToArray } from '@lib/citations/types';
import type { CitationReference } from '@lib/citations/types';
import InlineCitation from '@components/citations/InlineCitation.astro';
import Sources from '@components/citations/Sources.astro';

const citationDefs: CitationReference[] = [
  {
    hexCode: 'candidconc',
    title: 'U.S. Social Sector Dashboard — Money',
    url: 'https://candid.org/impact-insights/us-social-sector/money/',
    source: 'Candid',
  },
  {
    hexCode: 'altrata25',
    title: 'World Ultra Wealth Report 2025',
    url: 'https://altrata.com/reports/world-ultra-wealth-report-2025',
    source: 'Altrata',
    publishedDate: '2025-09-30',
  },
  {
    hexCode: 'cerulli84t',
    title: 'Cerulli Anticipates $84 Trillion in Wealth Transfers Through 2045',
    url: 'https://www.cerulli.com/press-releases/cerulli-anticipates-84-trillion-in-wealth-transfers-through-2045',
    source: 'Cerulli Associates',
    publishedDate: '2022-01-20',
  },
];

const citationIndex = buildCitationIndex(citationDefs);
const citationsArray = citationsToArray(citationIndex);

const pools = [
  {
    label: "Mega-foundations",
    sub: "Structured capital",
    tone: "var(--color-text-muted)",
    points: [
      { t: "Just 0.1% of U.S. grantmakers — those giving $50M+ a year — supply 40% of all grant dollars, out of 120,000+ foundations overall.", hex: 'candidconc' },
      { t: "Formal, RFP-driven cycles — big checks, but slower to decide.", hex: null },
      { t: "Predictable and legible: their giving history is on the public record.", hex: null },
    ],
  },
  {
    label: "New-money UHNWIs",
    sub: "Discretionary capital",
    tone: "var(--color-secondary)",
    points: [
      { t: "~511K ultra-high-net-worth individuals worldwide, net worth >$30M (2025).", hex: 'altrata25' },
      { t: "An $84.4T great wealth transfer is arriving through 2045 — ~$11.9T of it to charity.", hex: 'cerulli84t' },
      { t: "Large discretionary capacity — and a real appetite to deploy it.", hex: null },
    ],
  },
];
---

<section data-slot="03" data-variant="ref-v1" class="deck-section">
  <span class="deck-kicker">03 / 09</span>

  <div class="max-w-4xl">
    <p class="deck-eyebrow mb-3">Where the money concentrates</p>
    <h2 class="deck-h2">Two pools hold the <span class="deck-gradient">real capacity.</span></h2>
  </div>

  <div class="deck-grid mt-2" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
    {pools.map((p) => (
      <div class="deck-card flex flex-col gap-3">
        <div class="flex items-baseline justify-between gap-3">
          <span style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; color: var(--color-text);">{p.label}</span>
          <span class="deck-chip">{p.sub}</span>
        </div>
        <div class="deck-rule"></div>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.6rem;">
          {p.points.map((pt) => (
            <li style={`color: var(--color-text-muted); font-size: 0.96rem; line-height: 1.5; border-left: 3px solid ${p.tone}; padding-left: 0.75rem;`}>{pt.t}{pt.hex && citationIndex.get(pt.hex) && <InlineCitation {...citationIndex.get(pt.hex)!} />}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <p class="deck-lede mt-2" style="max-width: 74ch;">
    Different shapes, same lesson —
    <span style="color: var(--color-text); font-weight: 600;"> both are where the dollars pool, and both reward concentration over spray.</span>
  </p>

  <Sources citations={citationsArray} />
</section>
