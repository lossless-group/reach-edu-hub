---
/**
 * Slide 04 · Donor List Personalization (HNWI / SFO).
 *
 * Pillar 1 (Raise Better) made operational for the relationship-side
 * of the pipeline.
 */
const id = 'donor-personalization';

const work = [
  {
    n: 'I',
    title: 'Angle hypotheses',
    body: 'Develop concrete theses for how to promote existing donors to larger donors. Why might this donor, given what we know, double their commitment?',
  },
  {
    n: 'II',
    title: 'Interest-based content recommendations',
    body: 'Match what we have to what they care about. The right story, the right artifact, on the right week.',
  },
  {
    n: 'III',
    title: 'Personalized materials',
    body: 'Presentations, landing pages, and email templates that read as if written for them — because they were.',
  },
  {
    n: 'IV',
    title: 'Customized communication schedules',
    body: 'Cadence tuned to the donor, not the development calendar.',
  },
];
---

<section data-slot="05" data-variant="pipeline" id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-500 vibrant:text-orange-500">05 / 11</span>

  <div class="max-w-7xl">
    <div class="flex flex-wrap items-baseline gap-3 mb-6">
      <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500">Raise Better · The Relationship Side</p>
      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] uppercase tracking-[0.2em] font-mono border border-orange-500/50 text-orange-500 bg-orange-500/5">HNWI · SFO</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-5">
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight mb-6">
          Tailor the conversation to <em class="not-italic text-orange-500">the donor you already have.</em>
        </h2>
        <p class="font-serif italic text-base md:text-lg text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed mb-6">
          Enhance donor engagement by tailoring communications based on individual donor preferences, giving history, and interests.
        </p>
        <p class="font-serif text-sm text-slate-600 dark:text-slate-400 vibrant:text-cyan-300/80 leading-relaxed">
          The HNWI and SFO games are won on personal salience. Personalization isn’t a nice-to-have — it’s the whole instrument.
        </p>
      </div>

      <ol class="lg:col-span-7 divide-y divide-indigo-950/15 dark:divide-stone-50/15 vibrant:divide-orange-500/30">
        {work.map((w) => (
          <li class="grid grid-cols-12 gap-4 py-5 first:pt-0">
            <span class="col-span-2 md:col-span-1 font-serif text-xl md:text-2xl text-orange-500 leading-none pt-1">{w.n}</span>
            <div class="col-span-10 md:col-span-11">
              <h3 class="font-serif text-2xl md:text-3xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 mb-2 leading-tight">{w.title}</h3>
              <p class="text-base text-slate-700 dark:text-slate-400 vibrant:text-stone-50/80 leading-relaxed">{w.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
