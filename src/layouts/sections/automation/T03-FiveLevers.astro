---
/**
 * Slide 03 · Five Levers, Often Neglected.
 *
 * The lens behind every recommendation in this deck. Lands after the
 * archetype frame (T02) and before the roster (T04) so the levers can
 * re-key how the audience reads everything that follows — especially
 * "involve more people from Reach than you'd think appropriate."
 */
const id = 'five-levers';

const levers = [
  {
    n: 'I',
    title: 'Planned Serendipity',
    tagline: 'Going for luck.',
    body: 'Heatmap travel and outreach for anyone from Reach visiting a location — events, meetings, even holidays. Small travel-budget bumps go a long way. Involve more people from Reach than you’d think appropriate. Maximize inbound — SEO and GEO — so aligned people find us, not the other way around.',
  },
  {
    n: 'II',
    title: 'Authenticity & the Mechanics of Liking',
    tagline: 'Familiarity. Similarity. Frequency.',
    body: 'Work and personal relationships blur — find authentic ways of befriending. The care has to overcome the tacit knowledge that "all this is planned" — both are true; authenticity has to feel more true. Unique POV, recognizable voice, articulated belief pillars.',
  },
  {
    n: 'III',
    title: 'Slow Down to Speed Up',
    tagline: 'Tinker first. Codify second.',
    body: 'Build. Tinker. Experiment. Then codify and iterate on process mechanics and best-in-class tooling. Beat the Urgent-vs-Important trap and the Rainmaker-vs-Development trap. Long-term compounding never starts if every week is short-term firefighting.',
  },
  {
    n: 'IV',
    title: 'Pipelines Must Reflect Messy Reality',
    tagline: 'Simplicity is an overlay, not a denial.',
    body: 'The pipeline must reflect a messy reality — not be artificially simple. Simplicity can sit on top of the complexity, but the underlying data has to be honest. Oversimplified dashboards become unactionable and get ignored within a quarter.',
  },
  {
    n: 'V',
    title: 'The Coalition of the Willing',
    tagline: 'Goes commando. Leads by doing.',
    body: 'Convinces by showing the work, the impact, the productivity gains. Always welcome more of the Willing. Don’t let unwilling stakeholders freeze, pause, or delay initiatives. Move fast — anything skeptics doubted is either already scrapped (a valid experiment) or already iterated toward wowing them.',
  },
];
---

<section data-slot="03" data-variant="pipeline" id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-500 vibrant:text-orange-500">03 / 11</span>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 max-w-7xl">
    <div class="lg:col-span-4">
      <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-6">Operating Beliefs</p>
      <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight mb-6">
        Five levers.<br />
        <em class="not-italic text-orange-500">Often neglected.</em><br />
        Rarely well executed.
      </h2>
      <p class="font-serif italic text-base text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed">
        These shape what gets built, what gets prioritized, and where I push hardest when the room wants to default to something easier.
      </p>
    </div>

    <ol class="lg:col-span-8 divide-y divide-indigo-950/15 dark:divide-stone-50/15 vibrant:divide-orange-500/30">
      {levers.map((l) => (
        <li class="grid grid-cols-12 gap-4 py-5 first:pt-0">
          <span class="col-span-2 md:col-span-1 font-serif text-xl md:text-2xl text-orange-500 leading-none pt-1">{l.n}</span>
          <div class="col-span-10 md:col-span-11">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1.5">
              <h3 class="font-serif text-xl md:text-2xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-tight">{l.title}</h3>
              <span class="font-serif italic text-sm text-orange-500">{l.tagline}</span>
            </div>
            <p class="text-sm md:text-base text-slate-700 dark:text-slate-400 vibrant:text-stone-50/80 leading-relaxed">{l.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
