---
/**
 * Slide 10 · Theme Mapping — as analogy and literally. Payoff slide.
 *
 * The deck's closer: the multivariate map of who, where, and about-what.
 * Where the pipeline becomes a picture nobody at a peer institution has.
 */
const id = 'theme-mapping';

const axes = [
  { label: 'Who',         body: 'Funders, families, foundations — by tier and by recent activity.' },
  { label: 'Where',       body: 'Geographic concentration of dollars and of education-specific giving.' },
  { label: 'About-what',  body: 'Thematic concentration — workforce, access, AI literacy, rural, adult learners, more.' },
];
---

<section id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-500 vibrant:text-orange-500">11 / 11</span>

  <div class="max-w-7xl">
    <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-6">Theme Mapping · The Payoff</p>

    <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.04] tracking-tight max-w-5xl mb-10">
      Map the ideas the way you <em class="not-italic text-orange-500">map the places.</em>
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 mb-12">
      <div class="lg:col-span-7 space-y-6">
        <blockquote class="font-serif italic text-lg md:text-xl text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed border-l-2 border-orange-500 pl-5">
          Mapping themes is like mapping territories. Just as a map shows the boundaries and characteristics of different regions, theme mapping shows the boundaries and characteristics of different ideas and concepts.
        </blockquote>
        <blockquote class="font-serif italic text-lg md:text-xl text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed border-l-2 border-orange-500 pl-5">
          Yet, as we will have their location, themes can also be put on a digital map — creating a multivariate visualization of both geographic and thematic data.
        </blockquote>
      </div>

      <div class="lg:col-span-5">
        <p class="text-[11px] uppercase tracking-[0.3em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-4 font-medium">One image, three axes</p>
        <ul class="divide-y divide-indigo-950/15 dark:divide-stone-50/15 vibrant:divide-orange-500/30 border-y border-indigo-950/20 dark:border-stone-50/20 vibrant:border-orange-500/40">
          {axes.map((a) => (
            <li class="grid grid-cols-12 gap-3 py-4">
              <span class="col-span-4 font-serif text-2xl text-orange-500 leading-none pt-1">{a.label}</span>
              <p class="col-span-8 text-sm text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 font-serif italic leading-relaxed">{a.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-indigo-950/30 dark:border-stone-50/30 vibrant:border-orange-500/50 pt-8 max-w-4xl">
      <p class="font-serif text-xl md:text-2xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-relaxed">
        One map of the philanthropic landscape, with Reach’s position legible on it. <span class="text-orange-500">Nobody at a peer institution has this.</span>
      </p>
    </div>
  </div>
</section>
