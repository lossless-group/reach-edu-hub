---
/**
 * Slide 03 · Key Players We're Lifting.
 *
 * Roles + archetype chips showing where each role plays. The dependency
 * structure is visible without prose — the CEO has all three chips,
 * the grant writer has one.
 */
const id = 'key-players';

type Archetype = 'HNWI' | 'SFO' | 'Inst.';

const roles: { name: string; one_liner: string; plays: Archetype[] }[] = [
  {
    name: 'CEO',
    one_liner: 'The closer. Carries HNWI and SFO almost alone; named on the institutional pitch.',
    plays: ['HNWI', 'SFO', 'Inst.'],
  },
  {
    name: 'Travellers (any)',
    one_liner: 'The people in the room when the room matters. Trip planning, transcripts, follow-up.',
    plays: ['HNWI', 'SFO', 'Inst.'],
  },
  {
    name: 'Senior Reach Edu team member in any location',
    one_liner: 'The local face. Stewards relationships between visits.',
    plays: ['HNWI', 'SFO', 'Inst.'],
  },
  {
    name: 'Development officers',
    one_liner: 'The relationship-and-pipeline keepers. Heavy in SFO and institutional.',
    plays: ['SFO', 'Inst.'],
  },
  {
    name: 'Grant writers',
    one_liner: 'The engine of the institutional game.',
    plays: ['Inst.'],
  },
  {
    name: 'Involved donors',
    one_liner: 'The bench. Warm introductions, network leverage, board adjacency.',
    plays: ['HNWI', 'SFO'],
  },
];
---

<section data-slot="04" data-variant="pipeline" id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-500 vibrant:text-orange-500">04 / 11</span>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 max-w-7xl">
    <div class="lg:col-span-4">
      <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-6">Who Plays</p>
      <h2 class="font-serif text-4xl md:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight mb-6">
        Who gets <em class="not-italic text-orange-500">relief.</em><br />Who gets <em class="not-italic text-orange-500">leverage.</em>
      </h2>
      <p class="font-serif italic text-base text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed">
        Not every role plays in every archetype. We design the automations around the roles that actually carry the relationship.
      </p>
    </div>

    <ol class="lg:col-span-8 divide-y divide-indigo-950/15 dark:divide-stone-50/15 vibrant:divide-orange-500/30">
      {roles.map((r, i) => (
        <li class="grid grid-cols-12 gap-4 py-5 first:pt-0">
          <span class="col-span-2 md:col-span-1 font-serif text-xl md:text-2xl text-orange-500 leading-none pt-1">{String(i + 1).padStart(2, '0')}</span>
          <div class="col-span-10 md:col-span-11">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2 mb-2">
              <h3 class="font-serif text-xl md:text-2xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50">{r.name}</h3>
              <div class="flex flex-wrap gap-1.5">
                {r.plays.map((p) => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] uppercase tracking-[0.2em] font-mono border border-orange-500/50 text-orange-500 bg-orange-500/5">{p}</span>
                ))}
              </div>
            </div>
            <p class="text-sm md:text-base text-slate-700 dark:text-slate-400 vibrant:text-stone-50/80 leading-relaxed">{r.one_liner}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <p class="mt-12 max-w-3xl font-serif italic text-sm text-slate-600 dark:text-slate-400 vibrant:text-cyan-300/80 border-l-2 border-orange-500 pl-4">
    Three chips on a row means the role plays in every game. One chip means the role belongs to one game. The pipeline knows the difference.
  </p>
</section>
