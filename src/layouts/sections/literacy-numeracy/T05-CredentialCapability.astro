---
/**
 * Slide 05 · Credential ≠ Capability — certification and skill come apart.
 * Contrast layout: what's certified vs. what's assured, and the gap between.
 */
const columns = [
  {
    label: "Credential",
    sub: "What's certified",
    tone: "var(--color-text-muted)",
    points: [
      "A diploma confirms requirements were met and seat-time was served.",
      "It signals completion to an employer — a one-time marker.",
      "It assumes the underlying skills improved; it doesn't prove they did.",
    ],
  },
  {
    label: "Capability",
    sub: "What's assured",
    tone: "var(--color-secondary)",
    points: [
      "Real reading and math the graduate can demonstrably do.",
      "Travels with the worker across roles, employers, and years.",
      "It's the part the labor market actually pays for — net of the degree.",
    ],
  },
];
---

<section data-slot="05" data-variant="ln-v1" class="deck-section">
  <span class="deck-kicker">05 / 10</span>

  <div class="max-w-4xl">
    <p class="deck-eyebrow mb-3">The risk this removes</p>
    <h2 class="deck-h2">A degree can <span class="deck-gradient">certify</span> without lifting the basics.</h2>
  </div>

  <div class="deck-grid mt-2" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
    {columns.map((c) => (
      <div class="deck-card flex flex-col gap-3">
        <div class="flex items-baseline justify-between gap-3">
          <span style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; color: var(--color-text);">{c.label}</span>
          <span class="deck-chip">{c.sub}</span>
        </div>
        <div class="deck-rule"></div>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.6rem;">
          {c.points.map((pt) => (
            <li style={`color: var(--color-text-muted); font-size: 0.96rem; line-height: 1.5; border-left: 3px solid ${c.tone}; padding-left: 0.75rem;`}>{pt}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <p class="deck-lede mt-2" style="max-width: 74ch;">
    The space between the two is where the promise of a degree quietly leaks.
    <span style="color: var(--color-text); font-weight: 600;"> This strategy closes it — by lifting the capability, not just issuing the credential.</span>
  </p>
</section>
