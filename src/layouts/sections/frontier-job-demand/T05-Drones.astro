---
/**
 * Slide 05 · Drone Sciences — Field 02.
 * Mirrors T04-Manufacturing: demand stat → program shape → apprenticeship fit.
 * Figures verified 2026-07-06: Pilot Institute for $163.6B/13% CAGR; MorganHR
 * (citing PwC's 2024 Commercial Drone Survey) for 78% enterprise integration;
 * FAA Aerospace Forecast for the U.S. remote-pilot workforce figure.
 *
 * CORRECTED: the original "~650,000 drone-linked jobs (PwC)" figure was
 * actually PwC's 2022 "Skies Without Limits v2.0" UK-economy estimate, not a
 * U.S. figure — it was mismatched against the "U.S. drone industry" framing
 * of this stat block. Replaced with the FAA's own U.S. remote-pilot forecast.
 */
import { buildCitationIndex, citationsToArray } from '@lib/citations/types';
import type { CitationReference } from '@lib/citations/types';
import InlineCitation from '@components/citations/InlineCitation.astro';
import Sources from '@components/citations/Sources.astro';

const citationDefs: CitationReference[] = [
  {
    hexCode: 'pilotinst26',
    title: 'Statistics and Trends for Drones in 2026 and Beyond',
    url: 'https://pilotinstitute.com/drone-statistics/',
    source: 'Pilot Institute',
  },
  {
    hexCode: 'faauas25',
    title: 'FAA Aerospace Forecast: Unmanned Aircraft Systems',
    url: 'https://www.faa.gov/data_research/aviation/aerospace_forecasts/unmanned_aircraft_systems.pdf',
    source: 'Federal Aviation Administration',
  },
  {
    hexCode: 'morganhr24',
    title: 'Drone Operator Jobs 2030: AI-Powered Career Evolution',
    url: 'https://morganhr.com/blog/drone-operator-jobs-future-2030/',
    source: "MorganHR, citing PwC's 2024 Commercial Drone Survey",
  },
];

const citationIndex = buildCitationIndex(citationDefs);
const citationsArray = citationsToArray(citationIndex);

const covers = [
  "Drone manufacture",
  "The software stack",
  "Field deployment & operations",
  "Applications — inspection, agriculture, logistics, public safety",
];
---

<section data-slot="05" data-variant="fjd-v1" class="deck-section">
  <span class="deck-kicker">05 / 09</span>

  <div class="max-w-4xl">
    <p class="deck-eyebrow mb-3" style="font-family: var(--font-mono);">Field 02</p>
    <h2 class="deck-h2">Drone <span class="deck-gradient">Sciences.</span></h2>
  </div>

  <div class="flex items-baseline gap-4 flex-wrap mt-1">
    <span class="deck-stat" style="font-size: clamp(2.2rem, 5vw, 3.6rem);">$163.6B</span>
    <span class="deck-stat-label" style="max-width: 42ch;">
      projected U.S. drone industry by 2030 at ~13% CAGR.{citationIndex.get('pilotinst26') && <InlineCitation {...citationIndex.get('pilotinst26')!} />}
      The FAA projects U.S. registered remote pilots will grow from ~369,000 (2023) to over 472,000 within five years,{citationIndex.get('faauas25') && <InlineCitation {...citationIndex.get('faauas25')!} />}
      and ~78% of enterprises plan to integrate drone operations with existing business systems.{citationIndex.get('morganhr24') && <InlineCitation {...citationIndex.get('morganhr24')!} />}
    </span>
  </div>

  <div class="deck-grid mt-1" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
    <div class="deck-card flex flex-col gap-2">
      <span class="deck-stat-label" style="color: var(--color-secondary);">The program</span>
      <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.45rem;">
        {covers.map((c) => (
          <li style="color: var(--color-text); font-size: 0.96rem; line-height: 1.45; padding-left: 1rem; border-left: 2px solid var(--color-accent);">{c}</li>
        ))}
      </ul>
    </div>
    <div class="deck-card flex flex-col gap-2">
      <span class="deck-stat-label" style="color: var(--color-accent);">Why apprenticeship fits</span>
      <p style="color: var(--color-text); font-size: 0.96rem; line-height: 1.5; margin: 0;">
        An emerging field that no catalog has caught up to — anchored by the
        <strong> FAA Part 107</strong> remote-pilot credential and learned hands-on.
        Employer-pulled and changing too fast to teach anywhere but in the work.
      </p>
    </div>
  </div>

  <Sources citations={citationsArray} />
</section>
