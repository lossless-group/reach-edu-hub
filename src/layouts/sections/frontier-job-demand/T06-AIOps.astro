---
/**
 * Slide 06 · AI in Business Operations — Field 03.
 * Mirrors T04-Manufacturing: demand stat → program shape → apprenticeship fit.
 * Figures verified 2026-07-06: Gloat for 90%/9%; BCG for the US 50-55%
 * reshaped-in-2-3-years figure; PwC's 2026 Global AI Jobs Barometer for the
 * 2x-growth/42%-wage figures ("professionalised" vs. "democratised" jobs).
 */
import { buildCitationIndex, citationsToArray } from '@lib/citations/types';
import type { CitationReference } from '@lib/citations/types';
import InlineCitation from '@components/citations/InlineCitation.astro';
import Sources from '@components/citations/Sources.astro';

const citationDefs: CitationReference[] = [
  {
    hexCode: 'gloat2026',
    title: 'AI Skills Demand in the U.S. Job Market (2026)',
    url: 'https://gloat.com/blog/ai-skills-demand/',
    source: 'Gloat',
  },
  {
    hexCode: 'bcg2026',
    title: 'AI Will Reshape More Jobs Than It Replaces',
    url: 'https://www.bcg.com/publications/2026/ai-will-reshape-more-jobs-than-it-replaces',
    source: 'BCG',
    publishedDate: '2026-04-03',
  },
  {
    hexCode: 'pwcjb2026',
    title: '2026 Global AI Jobs Barometer',
    url: 'https://www.pwc.com/gx/en/services/ai/ai-jobs-barometer.html',
    source: 'PwC',
    publishedDate: '2026-06-15',
  },
];

const citationIndex = buildCitationIndex(citationDefs);
const citationsArray = citationsToArray(citationIndex);

const covers = [
  "Workflow automation",
  "Analysis & decision support",
  "Agentic tools in the daily workflow",
  "Not building frontier models — applying AI inside operations",
];
---

<section data-slot="06" data-variant="fjd-v1" class="deck-section">
  <span class="deck-kicker">06 / 09</span>

  <div class="max-w-4xl">
    <p class="deck-eyebrow mb-3" style="font-family: var(--font-mono);">Field 03</p>
    <h2 class="deck-h2">AI in Business <span class="deck-gradient">Operations.</span></h2>
  </div>

  <div class="flex items-baseline gap-4 flex-wrap mt-1">
    <span class="deck-stat" style="font-size: clamp(2.2rem, 5vw, 3.6rem);">~90% / ~9%</span>
    <span class="deck-stat-label" style="max-width: 44ch;">
      of organizations use AI in operations, but only ~9% are "AI-mature"{citationIndex.get('gloat2026') && <InlineCitation {...citationIndex.get('gloat2026')!} />} — a vast operationalization gap.
      BCG: ~50–55% of U.S. jobs reshaped in 2–3 years.{citationIndex.get('bcg2026') && <InlineCitation {...citationIndex.get('bcg2026')!} />}
    </span>
  </div>

  <div class="deck-grid mt-1" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
    <div class="deck-card flex flex-col gap-2">
      <span class="deck-stat-label" style="color: var(--color-secondary);">The program</span>
      <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.45rem;">
        {covers.map((c) => (
          <li style="color: var(--color-text); font-size: 0.96rem; line-height: 1.45; padding-left: 1rem; border-left: 2px solid var(--color-accent);">{c}</li>
        ))}
      </ul>
    </div>
    <div class="deck-card flex flex-col gap-2">
      <span class="deck-stat-label" style="color: var(--color-accent);">Why apprenticeship fits</span>
      <p style="color: var(--color-text); font-size: 0.96rem; line-height: 1.5; margin: 0;">
        Every employer needs this now, and it's learned in the actual workflow.
        Working adults become the people who make AI deliver — with
        <strong> ~2× faster role growth and ~42% faster wages</strong>
        for AI-"professionalized" work.{citationIndex.get('pwcjb2026') && <InlineCitation {...citationIndex.get('pwcjb2026')!} />}
      </p>
    </div>
  </div>

  <Sources citations={citationsArray} />
</section>
