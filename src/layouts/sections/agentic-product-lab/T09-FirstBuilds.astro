---
/**
 * Slide 09 · First Builds — candidate stack gaps to prototype first.
 * Cards drawn from the "different stack" requirements.
 */
import { buildCitationIndex, citationsToArray } from '@lib/citations/types';
import type { CitationReference } from '@lib/citations/types';
import InlineCitation from '@components/citations/InlineCitation.astro';
import Sources from '@components/citations/Sources.astro';

const citationDefs: CitationReference[] = [
  {
    hexCode: 'jffwbl',
    title: 'Work-Based Learning Glossary',
    url: 'https://www.jff.org/idea/work-based-learning-glossary/',
    source: 'Jobs for the Future (JFF)',
  },
];

const citationIndex = buildCitationIndex(citationDefs);
const citationsArray = citationsToArray(citationIndex);

const builds = [
  { tag: "Work ↔ credit", k: "Work–credit mapping", d: "Capture on-the-job work and map it to competencies and credit (e.g. the ~144 hrs/year of related instruction time-based Registered Apprenticeship requires) in an accreditation-legible way.", verify: true },
  { tag: "Visibility", k: "Employer dashboard", d: "Lightweight supervisor visibility and nudges, so the employer can see and encourage progress.", verify: false },
  { tag: "Delivery", k: "Chunked delivery + assessment", d: "Microlearning and stackable assessment sized for shifts — delivered and answered by voice when hands are full.", verify: false },
  { tag: "Evidence", k: "Accreditation evidence capture", d: "Turn messy work artifacts — voice notes, photos, logs — into the documentation accreditors expect.", verify: false },
];
---

<section data-slot="09" data-variant="forge-v1" class="deck-section">
  <span class="deck-kicker">09 / 10</span>

  <div class="max-w-4xl">
    <p class="deck-eyebrow mb-3" style="font-family: var(--font-mono);">First builds</p>
    <h2 class="deck-h2">The stack gaps to <span class="deck-gradient">prototype first.</span></h2>
  </div>

  <div class="deck-grid mt-2 items-stretch" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
    {builds.map((b) => (
      <div class="deck-card flex flex-col gap-2">
        <span class="deck-stat-label" style="color: var(--color-secondary);">{b.tag}</span>
        <p style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 700; color: var(--color-text); margin: 0;">{b.k}</p>
        <p style="color: var(--color-text-muted); font-size: 0.93rem; line-height: 1.5; margin: 0;">
          {b.d}{b.verify && citationIndex.get('jffwbl') && <InlineCitation {...citationIndex.get('jffwbl')!} />}
        </p>
      </div>
    ))}
  </div>

  <div class="deck-card mt-2" style="border-left: 3px solid var(--color-accent);">
    <p class="deck-stat-label" style="color: var(--color-accent); margin-bottom: 0.5rem;">Voice-first · for teachers &amp; nurses on the go</p>
    <p style="color: var(--color-text); font-size: 1.02rem; line-height: 1.6; margin: 0; max-width: 88ch;">
      The job is real-time application — not writing a dissertation. <strong style="font-weight: 700;">Speech-to-text</strong> lets an apprentice capture evidence in the moment, between classes or after rounds, turning small bits of time into accreditation-ready documentation. <strong style="font-weight: 700;">Text-to-speech</strong> turns the commute into learning time. Assessment meets the working adult where they already are — hands full, on the move, mid-shift.
    </p>
  </div>

  <p class="deck-lede mt-2" style="max-width: 74ch;">
    A starting menu, not a roadmap —
    <span style="color: var(--color-text); font-weight: 600;"> to be prioritized with members.</span>
  </p>

  <Sources citations={citationsArray} />
</section>
