---
/**
 * Slide 02 · A Different Stack — the Apprenticeship Degree needs software
 * incumbents didn't build. Three requirements + accreditation tie-off.
 */
import { buildCitationIndex, citationsToArray } from '@lib/citations/types';
import type { CitationReference } from '@lib/citations/types';
import InlineCitation from '@components/citations/InlineCitation.astro';
import Sources from '@components/citations/Sources.astro';

const citationDefs: CitationReference[] = [
  {
    hexCode: 'jffwbl',
    title: 'Work-Based Learning Glossary',
    url: 'https://www.jff.org/idea/work-based-learning-glossary/',
    source: 'Jobs for the Future (JFF)',
  },
];

const citationIndex = buildCitationIndex(citationDefs);
const citationsArray = citationsToArray(citationIndex);

const reqs = [
  { tag: "Integrate", k: "Work & learning are one thing", d: "Day-to-day application on the job IS the curriculum — not a separate course bolted on after the shift." },
  { tag: "Make visible", k: "Employer visibility & encouragement", d: "Supervisors can see an apprentice's progress and nudge it — the employer is part of the loop, not a bystander." },
  { tag: "Right-size", k: "Chunked delivery + assessment", d: "Sized for busy working adults — microlearning and stackable assessment, not semester blocks." },
];
---

<section data-slot="02" data-variant="forge-v1" class="deck-section">
  <span class="deck-kicker">02 / 10</span>

  <div class="max-w-4xl">
    <p class="deck-eyebrow mb-3" style="font-family: var(--font-mono);">The requirement</p>
    <h2 class="deck-h2">The Apprenticeship Degree runs on a <span class="deck-gradient">different stack.</span></h2>
  </div>

  <div class="deck-grid mt-2 items-stretch" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
    {reqs.map((r) => (
      <div class="deck-card flex flex-col gap-2">
        <span class="deck-stat-label" style="color: var(--color-secondary);">{r.tag}</span>
        <p style="font-family: var(--font-heading); font-size: 1.3rem; font-weight: 700; color: var(--color-text); margin: 0;">{r.k}</p>
        <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.5; margin: 0;">{r.d}</p>
      </div>
    ))}
  </div>

  <p class="deck-lede mt-2" style="max-width: 76ch;">
    All of it while still meeting credit-bearing accreditation — time-based
    Registered Apprenticeship requires a minimum of 144 hours of related instruction
    per year (plus ~2,000 hours of on-the-job learning), with competency-based
    pathways alongside.{citationIndex.get('jffwbl') && <InlineCitation {...citationIndex.get('jffwbl')!} />}
    <span style="color: var(--color-text); font-weight: 600;"> It's not a campus, and not even an online program.</span>
  </p>

  <Sources citations={citationsArray} />
</section>
