---
/**
 * Slide 05 · Travel (Front 02) — outreach, meeting setup, drive-time, follow-up.
 * Follows the T04-ABM front template.
 */
const paid = ["Trip Planner AI", "Reclaim.ai", "Clockwise", "Calendly", "Badger Maps", "Circuit"];
const oss = ["n8n"];
---

<section data-slot="05" data-variant="awm-v1" class="deck-section">
  <span class="deck-kicker">05 / 11</span>

  <div class="max-w-4xl">
    <p class="deck-eyebrow mb-3" style="font-family: var(--font-mono);">Front 02 · Travel</p>
    <h2 class="deck-h2">A trip worth taking, <span class="deck-gradient">planned for you.</span></h2>
  </div>

  <div class="deck-grid mt-2" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
    <div class="deck-card flex flex-col gap-2">
      <span class="deck-stat-label" style="color: var(--color-accent);">The bottleneck</span>
      <p style="color: var(--color-text); font-size: 0.98rem; line-height: 1.55; margin: 0;">
        A trip only pays off if you stack enough meetings to justify it — sequenced
        sanely by geography, with prep and follow-up. Hours of glue work per trip.
      </p>
    </div>
    <div class="deck-card flex flex-col gap-2">
      <span class="deck-stat-label" style="color: var(--color-secondary);">Agents do</span>
      <p style="color: var(--color-text); font-size: 0.98rem; line-height: 1.55; margin: 0;">
        Build the itinerary, run outreach to fill meetings around the dates,
        optimize the day-by-day route and drive time, schedule, and queue follow-ups.
      </p>
    </div>
  </div>

  <div class="flex items-baseline gap-4 flex-wrap mt-1">
    <span class="deck-stat" style="font-size: clamp(2rem, 4vw, 3.2rem);">minutes <span class="deck-verify">VERIFY</span></span>
    <span class="deck-stat-label" style="max-width: 42ch;">AI trip planners generate full itineraries "in minutes"; field-sales route tools cut windshield time — soft / illustrative</span>
  </div>

  <div class="flex flex-col gap-2 mt-1">
    <p class="deck-stat-label">Tools</p>
    <div class="flex flex-wrap gap-2 items-center">
      <span class="deck-stat-label" style="color: var(--color-accent);">Paid</span>
      {paid.map((t) => <span class="deck-chip">{t}</span>)}
      <span class="deck-stat-label" style="color: var(--color-secondary); margin-left: 0.5rem;">Open</span>
      {oss.map((t) => <span class="deck-chip">{t}</span>)}
    </div>
  </div>
</section>
