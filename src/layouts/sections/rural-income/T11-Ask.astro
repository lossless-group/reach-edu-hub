---
/**
 * Slide 11 · The Ask — scale + the call to co-fund. Closing flourish.
 */
const next = [
  { k: "Reach", d: "Delivers the model, the credential, and the rural cohort outcomes — and scales it through NCAD." },
  { k: "Funders", d: "Co-fund across the pipeline so national grants reach regional match and local delivery." },
];
---

<section data-slot="11" data-variant="v1" class="deck-section deck-glow" style="justify-content: center;">
  <span class="deck-kicker">11 / 11</span>

  <div class="max-w-5xl">
    <p class="deck-eyebrow mb-5">Scale & the ask</p>

    <div class="flex flex-col gap-2 mb-8">
      <span class="deck-stat">3 million <span class="deck-verify">VERIFY</span></span>
      <p class="deck-stat-label">Apprenticeship Degree completions by 2035 · anchored by NCAD</p>
    </div>

    <h2 class="deck-h2 mb-8">Let's fund the next rural cohorts — <span class="deck-gradient">together.</span></h2>

    <div class="deck-grid mb-8" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
      {next.map((n) => (
        <div class="flex flex-col gap-1">
          <span class="deck-stat-label" style="color: var(--color-secondary);">{n.k}</span>
          <p style="color: var(--color-text-muted); font-size: 1rem; line-height: 1.5; margin: 0;">{n.d}</p>
        </div>
      ))}
    </div>

    <div class="deck-rule mb-8" style="max-width: 14rem;"></div>

    <p class="deck-lede" style="max-width: 60ch; color: var(--color-text); font-size: clamp(1.2rem, 2vw, 1.7rem);">
      The raise is the point — and the income stays local.
    </p>
  </div>
</section>
