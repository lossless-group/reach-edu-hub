---
/**
 * Slide 04 v2 · Affordability. Massive serif "$75/month" centered, dramatic.
 */
const id = 'affordability';
---

<section id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-white dark:bg-slate-950 vibrant:bg-indigo-950 snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-600 vibrant:text-orange-500">04 / 09</span>

  <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-12 text-center">Affordability</p>

  <div class="text-center mb-16">
    <p class="font-serif italic text-base md:text-lg text-slate-600 dark:text-slate-400 vibrant:text-cyan-300 mb-4">Out-of-pocket cost for a B.A., after financial aid:</p>
    <div class="flex items-baseline justify-center">
      <span class="font-serif text-[8rem] md:text-[14rem] lg:text-[18rem] leading-[0.85] text-indigo-950 dark:text-stone-50 vibrant:text-orange-500">$75</span>
      <span class="font-serif italic text-3xl md:text-5xl text-orange-500 dark:text-cyan-400 vibrant:text-stone-50 ml-3">/month</span>
    </div>
    <p class="mt-6 font-mono text-xs uppercase tracking-[0.4em] text-slate-500 dark:text-slate-500 vibrant:text-cyan-300">Capped. Not a starting price.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto border-t border-indigo-950/15 dark:border-stone-50/15 vibrant:border-orange-500/40 pt-10">
    <div>
      <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-3">Two B.A. programs</p>
      <p class="font-serif text-base italic text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed">B.A. in Liberal Studies and B.A. in Global Education both cap at $75/month.</p>
    </div>
    <div>
      <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-3">Why this works</p>
      <p class="font-serif text-base italic text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed">Affordability is structural — employers and the workplace carry the practicum.</p>
    </div>
    <div>
      <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-3">Graduate caveat</p>
      <p class="font-serif text-base italic text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed">Graduate programs route affordability through employer and county-grant pathways.</p>
    </div>
  </div>

  <p class="mt-16 text-center font-serif text-xl md:text-2xl italic text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 max-w-3xl mx-auto">
    "Nobody should be forced to choose between a job and a degree."
  </p>
</section>
