---
/**
 * Slide 05 v2 · Faculty. Quote-driven; named exemplars in side column.
 */
const id = 'faculty';
---

<section id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-500 vibrant:text-orange-500">05 / 09</span>

  <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-8">Faculty</p>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-7xl">
    <div class="lg:col-span-7 lg:border-r lg:border-indigo-950/15 dark:lg:border-stone-50/15 vibrant:lg:border-orange-500/30 lg:pr-12">
      <h2 class="font-serif text-4xl md:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight mb-8">
        Faculty still doing the job they teach.
      </h2>
      <p class="font-serif text-lg italic text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed mb-6">
        Reach faculty work full-time in classrooms alongside the candidates they teach — same challenges, same calendar, same students.
      </p>
      <p class="font-serif text-lg italic text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed mb-10">
        Live seminars, not asynchronous video. <span class="not-italic font-semibold text-indigo-950 dark:text-stone-50 vibrant:text-orange-500">25:1 student-to-faculty ratio.</span>
      </p>

      <div class="border-l-4 border-orange-500 pl-6 py-2">
        <p class="font-serif text-xl italic text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-snug">
          "We value professors who are immersed in their real-life work — because they make better teachers."
        </p>
      </div>
    </div>

    <div class="lg:col-span-5 flex flex-col justify-between">
      <div>
        <p class="font-serif text-7xl md:text-9xl text-orange-500 leading-none">~50<span class="text-4xl md:text-6xl align-top">%</span></p>
        <p class="mt-4 font-serif text-lg italic text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85 leading-relaxed max-w-sm">
          of Reach's faculty are former <span class="not-italic font-semibold text-indigo-950 dark:text-stone-50 vibrant:text-orange-500">Teachers or Principals of the Year</span> in their home states.
        </p>
      </div>

      <div class="mt-12 pt-6 border-t border-indigo-950/15 dark:border-stone-50/15 vibrant:border-orange-500/30">
        <p class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-4">Named exemplars</p>
        <ul class="space-y-3">
          <li class="font-serif text-base text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85">
            <span class="font-semibold text-indigo-950 dark:text-stone-50 vibrant:text-orange-500">Dr. Cicely Woodard</span><br />
            <span class="italic text-sm text-slate-500 dark:text-slate-400 vibrant:text-cyan-300">Presidential Award · 2018 Tennessee Teacher of the Year</span>
          </li>
          <li class="font-serif text-base text-slate-700 dark:text-slate-300 vibrant:text-stone-50/85">
            <span class="font-semibold text-indigo-950 dark:text-stone-50 vibrant:text-orange-500">Dr. Torrence Williams</span><br />
            <span class="italic text-sm text-slate-500 dark:text-slate-400 vibrant:text-cyan-300">2017 Louisiana High School Teacher of the Year</span>
          </li>
        </ul>
        <p class="mt-6 font-mono text-xs uppercase tracking-widest text-slate-500 dark:text-slate-500 vibrant:text-cyan-300/80">~250 faculty &amp; professors of practice university-wide</p>
      </div>
    </div>
  </div>
</section>
