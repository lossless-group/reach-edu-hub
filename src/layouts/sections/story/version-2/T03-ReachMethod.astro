---
/**
 * Slide 03 v2 · Method. Vertical numbered list, editorial column rhythm.
 */
const id = 'reach-method';

const principles = [
  { n: 'I',   title: 'Efficiency',           body: '50% of learning happens through on-the-job work the candidate is already doing.' },
  { n: 'II',  title: 'Flexibility',          body: 'Live seminars run evenings and weekends, designed around full-time work.' },
  { n: 'III', title: 'Relevance',            body: '100% job-embedded curriculum — theory connects to a practice the candidate performs that week.' },
  { n: 'IV',  title: 'Affordability',        body: 'Candidates are paid while studying and graduate with zero student debt.' },
  { n: 'V',   title: 'Professional Capital', body: 'Graduates advance inside the employer who sponsored them — retention deepens on both sides.' },
];
---

<section data-slot="03" data-variant="editorial" id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-stone-50 dark:bg-indigo-950 vibrant:bg-black snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-500 vibrant:text-orange-500">03 / 09</span>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-7xl">
    <div class="lg:col-span-4">
      <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-6">The Method</p>
      <h2 class="font-serif text-4xl md:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight mb-6">
        Five non-<br />negotiables.
      </h2>
      <p class="font-serif italic text-base text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 leading-relaxed">
        Together they define what "fully job-embedded" actually means — the standard NCAD is pushing other institutions to adopt.
      </p>
    </div>

    <ol class="lg:col-span-8 divide-y divide-indigo-950/15 dark:divide-stone-50/15 vibrant:divide-orange-500/30">
      {principles.map((p) => (
        <li class="grid grid-cols-12 gap-4 py-5 first:pt-0">
          <span class="col-span-2 md:col-span-1 font-serif text-xl md:text-2xl text-orange-500 leading-none pt-1">{p.n}</span>
          <div class="col-span-10 md:col-span-11">
            <h3 class="font-serif text-2xl md:text-3xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 mb-2">{p.title}</h3>
            <p class="text-base text-slate-700 dark:text-slate-400 vibrant:text-stone-50/75 leading-relaxed">{p.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <p class="mt-12 max-w-3xl font-serif italic text-sm text-slate-600 dark:text-slate-400 vibrant:text-cyan-300/80 border-l-2 border-orange-500 pl-4">
    "Efficient, flexible, relevant, affordable, and grounded in conferring professional capital." — President Joe E. Ross
  </p>
</section>
