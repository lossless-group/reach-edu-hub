---
/**
 * Slide 08 v2 · Scale & Traction. KPI grid; serif numerals dominate.
 */
const id = 'scale-traction';

const stats = [
  { value: '2020',    label: 'Founded',                     note: 'Nonprofit accredited institution' },
  { value: '20×',     label: 'Undergrad enrollment growth', note: 'Since founding' },
  { value: '2,600+',  label: 'Candidates served',           note: 'Nationwide' },
  { value: '400+',    label: 'Communities reached',         note: '' },
  { value: '$30M',    label: 'Grant commitments',           note: 'Private and public' },
  { value: '~50',     label: 'Coalition partners',          note: 'Higher-ed · state · employer · philanthropic' },
];
---

<section id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-white dark:bg-slate-950 vibrant:bg-indigo-950 snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest font-mono text-slate-400 dark:text-slate-600 vibrant:text-orange-500">08 / 09</span>

  <p class="text-xs uppercase tracking-[0.4em] text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500 mb-6">Scale &amp; Traction</p>

  <h2 class="font-serif text-4xl md:text-6xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-[1.05] tracking-tight max-w-4xl mb-4">
    Five years in. <em class="not-italic text-orange-500">Proven institutional shape.</em>
  </h2>
  <p class="font-serif italic text-lg text-slate-700 dark:text-slate-300 vibrant:text-cyan-300 max-w-3xl leading-relaxed mb-12">
    Accredited, growing 20×, funded, and reaching 400+ communities. <span class="not-italic font-semibold text-indigo-950 dark:text-stone-50 vibrant:text-orange-500">2024 WSCUC Reaffirmation of Accreditation.</span>
  </p>

  <dl class="grid grid-cols-2 md:grid-cols-3 gap-x-10 gap-y-12 max-w-6xl">
    {stats.map((s) => (
      <div class="border-t-2 border-orange-500 pt-4">
        <dd class="font-serif text-5xl md:text-6xl lg:text-7xl text-indigo-950 dark:text-stone-50 vibrant:text-stone-50 leading-none mb-3">{s.value}</dd>
        <dt class="font-mono text-xs uppercase tracking-widest text-cyan-700 dark:text-cyan-400 vibrant:text-orange-500">{s.label}</dt>
        {s.note && <p class="mt-1 font-serif italic text-xs text-slate-500 dark:text-slate-400 vibrant:text-cyan-300/80">{s.note}</p>}
      </div>
    ))}
  </dl>

  <p class="mt-12 max-w-4xl font-serif italic text-sm text-slate-600 dark:text-slate-400 vibrant:text-cyan-300/80 leading-relaxed">
    Founder Mallory Dwinal-Palisch (ex-Teach for America, co-founder Oxford Day Academy) remains as Senior Advisor; Joe E. Ross has been President &amp; CEO since January 2021.
  </p>
</section>
