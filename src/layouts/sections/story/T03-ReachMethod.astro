  },
  {
    n: '02',
    title: 'Flexibility',
    body: 'Live seminars run evenings and weekends, designed around full-time work.',
  },
  {
    n: '03',
    title: 'Relevance',
    body: '100% job-embedded curriculum — theory connects to a practice the candidate performs that week.',
