<section data-slot="02" data-variant="baseline" id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-gray-50 dark:bg-slate-800 vibrant:bg-slate-950 snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest text-gray-400 dark:text-slate-500 vibrant:text-orange-500/80 font-mono">02 / 09</span>

  <p class="text-xs uppercase tracking-[0.3em] text-gray-500 dark:text-slate-400 vibrant:text-orange-400 mb-12 text-center">Mission</p>

  <blockquote class="max-w-5xl mx-auto text-center">
    <p class="text-3xl md:text-5xl lg:text-6xl font-medium text-gray-900 dark:text-slate-50 vibrant:text-stone-50 leading-snug mb-10">
      "We envision a world where <span class="text-blue-700 dark:text-blue-400 vibrant:text-orange-500">skill and effort</span>, not money or connections, determine who gets ahead."
    </p>
    <footer class="text-sm uppercase tracking-widest text-gray-500 dark:text-slate-400 vibrant:text-orange-400">— Reach University</footer>
  </blockquote>

  <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
