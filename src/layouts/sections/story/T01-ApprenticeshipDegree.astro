---
/**
 * Slide 01 · apprenticeship-degree-model — opener / cover.
 * Source: src/content/messages/apprenticeship-degree-model.md
 */
const id = 'apprenticeship-degree';
---

<section id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-white snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest text-gray-400 font-mono">01 / 09</span>

  <p class="text-xs uppercase tracking-[0.3em] text-gray-500 mb-6">Reach University · The Apprenticeship Degree</p>

  <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-gray-900 leading-tight max-w-5xl mb-8">
    Turn your job into a degree.
  </h1>

  <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mb-16 leading-relaxed">
    A fully accredited college degree where the workplace is the classroom — roughly half the learning happens through on-the-job work, the rest through after-hours seminars.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-200 max-w-4xl border border-gray-200 rounded-sm overflow-hidden">
    <div class="bg-white p-6">
      <p class="text-3xl font-bold text-gray-900 mb-1">A</p>
      <p class="text-sm text-gray-500 uppercase tracking-wider mb-2">Affordable</p>
      <p class="text-sm text-gray-700">Earn a paycheck while earning the degree.</p>
    </div>
    <div class="bg-white p-6">
      <p class="text-3xl font-bold text-gray-900 mb-1">B</p>
      <p class="text-sm text-gray-500 uppercase tracking-wider mb-2">Based in the workplace</p>
      <p class="text-sm text-gray-700">The workplace transforms into a learning place.</p>
    </div>
    <div class="bg-white p-6">
      <p class="text-3xl font-bold text-gray-900 mb-1">C</p>
      <p class="text-sm text-gray-500 uppercase tracking-wider mb-2">Credit for the work you already do</p>
      <p class="text-sm text-gray-700">Real, fully accredited — not a certificate.</p>
    </div>
  </div>

  <p class="mt-12 text-sm text-gray-500 max-w-2xl">
    Sector goal: <span class="font-semibold text-gray-700">3 million Apprenticeship Degree completions by 2035</span> — driven by the National Center for the Apprenticeship Degree (NCAD), launched 2024.
  </p>
</section>
