---
/**
 * Slide 05 · professors-of-practice — split layout, big stat + named exemplars.
 * Source: src/content/messages/professors-of-practice.md
 */
const id = 'faculty';
---

<section id={id} class="relative min-h-screen flex flex-col justify-center px-8 md:px-16 lg:px-24 py-16 bg-white snap-start">
  <span class="absolute top-6 right-8 text-xs tracking-widest text-gray-400 font-mono">05 / 09</span>

  <p class="text-xs uppercase tracking-[0.3em] text-gray-500 mb-8">Faculty</p>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-6xl">
    <div class="lg:col-span-7">
      <h2 class="text-4xl md:text-6xl font-bold text-gray-900 leading-tight mb-6">
        Faculty still doing the job they teach.
      </h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        Reach faculty work full-time in classrooms alongside the candidates they teach — same challenges, same calendar, same students.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        Live seminars, not asynchronous video. <span class="font-semibold text-gray-900">25:1 student-to-faculty ratio.</span>
      </p>

      <div class="border-l-2 border-blue-700 pl-5 py-1">
        <p class="text-base italic text-gray-700">
          "We value professors who are immersed in their real-life work — because they make better teachers."
        </p>
      </div>
    </div>

    <div class="lg:col-span-5 flex flex-col justify-between bg-gray-50 border border-gray-200 rounded-sm p-8">
      <div>
        <p class="text-7xl md:text-8xl font-bold text-gray-900 leading-none">~50%</p>
        <p class="text-base text-gray-600 mt-3 leading-snug">
          of Reach's faculty are former <span class="font-semibold text-gray-900">Teachers or Principals of the Year</span> in their home states.
        </p>
      </div>

      <div class="mt-10 pt-6 border-t border-gray-200">
        <p class="text-xs uppercase tracking-wider text-gray-500 mb-3">Named exemplars</p>
        <ul class="space-y-2 text-sm text-gray-700">
          <li><span class="font-semibold">Dr. Cicely Woodard</span> — Presidential Award; 2018 Tennessee Teacher of the Year</li>
          <li><span class="font-semibold">Dr. Torrence Williams</span> — 2017 Louisiana High School Teacher of the Year</li>
        </ul>
        <p class="mt-4 text-xs text-gray-500">
          Nearly 250 faculty and professors of practice university-wide.
        </p>
      </div>
    </div>
  </div>
</section>
