---
export interface Props {
  title?: string;
  description?: string;
  themeClass?: string;
  mode?: string;
  favicon?: string;
}

const {
  title = "Reach Education Hub",
  description = "Client hub for Reach University materials and content",
  themeClass = "theme-default",
  mode = "light",
  favicon = "/favicon.svg",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class={themeClass} data-theme={themeClass.replace('theme-', '')} data-mode={mode}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={favicon} />
</head>
<body>
  <slot />
</body>
</html>
