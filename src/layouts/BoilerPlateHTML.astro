---
/**
 * BoilerPlateHTML — bare HTML shell with no-flash mode boot script and
 * full SEO/OG meta delegated to MetaTags.
 *
 * Use this directly only when bypassing BaseThemeLayout (e.g., the deck
 * pages that need a non-standard body layout). Most pages should use
 * BaseThemeLayout, which wraps this with Header + Footer.
 */
import MetaTags from '../components/basics/MetaTags.astro';

export interface Props {
  title?: string;
  description?: string;
  themeClass?: string;
  mode?: string;
  favicon?: string;
  /** OG image override — path under /public or absolute URL. */
  ogImage?: string;
  ogImageAlt?: string;
  /** "website" (default), "article", etc. */
  ogType?: string;
  /** Defaults to false — the hub is public. Set true for internal/private pages. */
  noindex?: boolean;
  /** Article-only fields, emitted only when ogType === "article". */
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
}

const {
  title = 'Reach goes Lossless',
  description = 'A working hub for Reach University × The Lossless Group.',
  themeClass = 'theme-default',
  mode = 'light',
  favicon = '/reach-favicon.png',
  ogImage,
  ogImageAlt,
  ogType,
  noindex,
  publishedTime,
  modifiedTime,
  author,
  tags,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class={themeClass} data-theme={themeClass.replace('theme-', '')} data-mode={mode}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href={favicon} />

  <MetaTags
    title={title}
    description={description}
    ogImage={ogImage}
    ogImageAlt={ogImageAlt}
    ogType={ogType}
    noindex={noindex}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    author={author}
    tags={tags}
  />

  {/* No-flash mode boot — runs before first paint, syncs <html> with localStorage
      ahead of the mode-switcher.js module load. Must stay inline + synchronous. */}
  <script is:inline>
    (function () {
      try {
        var stored = localStorage.getItem('mode');
        var valid = ['light', 'dark', 'vibrant'];
        var sysLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
        var mode = valid.indexOf(stored) !== -1 ? stored : (sysLight ? 'light' : 'dark');
        var html = document.documentElement;
        html.setAttribute('data-mode', mode);
        if (mode === 'dark' || mode === 'vibrant') {
          html.classList.add('dark');
        } else {
          html.classList.remove('dark');
        }
      } catch (e) { /* swallow — mode-switcher.js will retry */ }
    })();
  </script>
</head>
<body>
  <slot />
</body>
</html>
