---
/**
 * Header — site chrome. Thin 3-column grid:
 *   wordmark (links to /)  ·  centered nav with active state  ·  ModeToggle
 *
 * Pattern stolen from sites/calmstorm-decks/src/components/basics/DeckHeader.astro,
 * adapted to use Tailwind built-in tokens with the dark: and vibrant: variants
 * wired in src/styles/global.css. No var(--theme-*) references — palette is
 * hardcoded so the header reads correctly in all three modes.
 *
 * Used by BaseThemeLayout. Deck pages (/story, /story/version-2) bypass
 * BaseThemeLayout and render their own minimal chrome.
 */
import ModeToggle from '../ui/ModeToggle.astro';
import { getScrollDeckCycle } from '../../lib/scroll-decks';

const path = Astro.url.pathname;
const onStory        = path.startsWith('/story');
const onAutomation   = path.startsWith('/automation');
const onBrandKit     = path.startsWith('/brand-kit');
const onDesignSystem = path.startsWith('/design-system');
const onChangelog    = path.startsWith('/changelog');
const onHome         = !onStory && !onAutomation && !onBrandKit && !onDesignSystem && !onChangelog;

const scrollCycle = getScrollDeckCycle(path);

const linkBase     = 'no-underline transition-colors hover:text-indigo-950 dark:hover:text-stone-50 vibrant:hover:text-orange-500';
const linkActive   = 'text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 font-medium';
const linkInactive = 'text-slate-500 dark:text-slate-400 vibrant:text-cyan-300';
const sep          = 'text-slate-300 dark:text-slate-700 vibrant:text-orange-500/40';
const arrowBtn     = 'inline-flex h-5 w-5 items-center justify-center rounded-full text-slate-500 dark:text-slate-400 vibrant:text-cyan-300 hover:bg-slate-100 dark:hover:bg-stone-50/10 vibrant:hover:bg-orange-500/15 hover:text-indigo-950 dark:hover:text-stone-50 vibrant:hover:text-orange-500 no-underline tracking-normal transition-colors';
---

<header class="sticky top-0 z-50 h-12 shrink-0 grid grid-cols-3 items-center px-6 border-b bg-white dark:bg-indigo-950 vibrant:bg-black border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/40">
  <a
    href="/"
    class="justify-self-start inline-flex items-center gap-2.5 text-sm font-light tracking-[0.25em] uppercase no-underline text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 hover:text-cyan-700 dark:hover:text-cyan-400 vibrant:hover:text-stone-50 transition-colors"
  >
    <img
      src="/reach-favicon.png"
      alt=""
      aria-hidden="true"
      class="w-7 h-7 rounded-full bg-white object-cover shrink-0 ring-1 ring-slate-200 dark:ring-stone-50/20 vibrant:ring-orange-500/50"
    />
    <span>Reach<span class={`mx-1.5 ${sep}`}>·</span>Hub</span>
  </a>

  <nav class="justify-self-center flex items-center gap-3 text-[10px] tracking-[0.25em] uppercase" aria-label="Primary">
    <a href="/"              class:list={[linkBase, onHome         ? linkActive : linkInactive]}>Hub</a>
    <span class={sep} aria-hidden="true">·</span>
    <a href="/story"         class:list={[linkBase, onStory        ? linkActive : linkInactive]}>Story</a>
    <span class={sep} aria-hidden="true">·</span>

    {scrollCycle && (
      <>
        <span
          class="inline-flex items-center gap-1 rounded-full border border-slate-200 dark:border-stone-50/20 vibrant:border-orange-500/40 bg-white/80 dark:bg-indigo-950/80 vibrant:bg-black/80 backdrop-blur-sm pl-1 pr-1 py-0.5"
          aria-label="Switch story variant"
        >
          <a
            href={scrollCycle.prev}
            aria-label="Previous story variant"
            class={arrowBtn}
          >‹</a>
          <span class="text-[10px] tracking-[0.2em] tabular-nums text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 whitespace-nowrap px-2">
            {scrollCycle.current.label}
            <span class="text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/60 normal-case ml-1.5">({scrollCycle.index}/{scrollCycle.total})</span>
          </span>
          <a
            href={scrollCycle.next}
            aria-label="Next story variant"
            class={arrowBtn}
          >›</a>
        </span>
        <span class={sep} aria-hidden="true">·</span>
      </>
    )}

    <a href="/automation"   class:list={[linkBase, onAutomation   ? linkActive : linkInactive]}>Automation</a>
    <span class={sep} aria-hidden="true">·</span>
    <a href="/brand-kit"     class:list={[linkBase, onBrandKit     ? linkActive : linkInactive]}>Brand Kit</a>
    <span class={sep} aria-hidden="true">·</span>
    <a href="/design-system" class:list={[linkBase, onDesignSystem ? linkActive : linkInactive]}>Design System</a>
    <span class={sep} aria-hidden="true">·</span>
    <a href="/changelog"     class:list={[linkBase, onChangelog    ? linkActive : linkInactive]}>Changelog</a>
  </nav>

  <div class="justify-self-end">
    <ModeToggle />
  </div>
</header>
