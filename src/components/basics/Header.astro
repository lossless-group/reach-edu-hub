---
/**
 * Header — site chrome. Thin 3-column grid:
 *   wordmark (links to /)  ·  centered nav with active state  ·  ModeToggle
 *
 * Pattern stolen from sites/calmstorm-decks/src/components/basics/DeckHeader.astro,
 * adapted to use Tailwind built-in tokens with the dark: and vibrant: variants
 * wired in src/styles/global.css. No var(--theme-*) references — palette is
 * hardcoded so the header reads correctly in all three modes.
 *
 * Used by BaseThemeLayout. Deck pages (/story, /story/version-2) bypass
 * BaseThemeLayout and render their own minimal chrome.
 */
import ModeToggle from '../ui/ModeToggle.astro';
import { getScrollDeckCycle } from '../../lib/scroll-decks';

const path = Astro.url.pathname;
const onStory        = path.startsWith('/scroll/story');
const onAutomation   = path.startsWith('/scroll/automation');
const onStrategies   = path.startsWith('/strategies') || (path.startsWith('/scroll/') && !onStory && !onAutomation);
const onBrandKit     = path.startsWith('/brand-kit');
const onDesignSystem = path.startsWith('/design-system');
const onChangelog    = path.startsWith('/changelog');
const onHome         = !onStory && !onAutomation && !onStrategies && !onBrandKit && !onDesignSystem && !onChangelog;

const scrollCycle = getScrollDeckCycle(path);

const linkBase     = 'no-underline transition-colors hover:text-indigo-950 dark:hover:text-stone-50 vibrant:hover:text-orange-500';
const linkActive   = 'text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 font-medium';
const linkInactive = 'text-slate-500 dark:text-slate-400 vibrant:text-cyan-300';
const sep          = 'text-slate-300 dark:text-slate-700 vibrant:text-orange-500/40';
const arrowBtn     = 'inline-flex h-5 w-5 items-center justify-center rounded-full text-slate-500 dark:text-slate-400 vibrant:text-cyan-300 hover:bg-slate-100 dark:hover:bg-stone-50/10 vibrant:hover:bg-orange-500/15 hover:text-indigo-950 dark:hover:text-stone-50 vibrant:hover:text-orange-500 no-underline tracking-normal transition-colors';
---

<header class="sticky top-0 z-50 h-12 shrink-0 grid grid-cols-3 items-center px-6 border-b bg-white dark:bg-indigo-950 vibrant:bg-black border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/40">
  <a
    href="/"
    class="justify-self-start inline-flex items-center gap-2.5 text-sm font-light tracking-[0.25em] uppercase no-underline text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 hover:text-cyan-700 dark:hover:text-cyan-400 vibrant:hover:text-stone-50 transition-colors"
  >
    <img
      src="/reach-favicon.png"
      alt=""
      aria-hidden="true"
      class="w-7 h-7 rounded-full bg-white object-cover shrink-0 ring-1 ring-slate-200 dark:ring-stone-50/20 vibrant:ring-orange-500/50"
    />
    <span>Reach<span class={`mx-1.5 ${sep}`}>·</span>Hub</span>
  </a>

  <nav class="justify-self-center flex items-center gap-3 text-[10px] tracking-[0.25em] uppercase" aria-label="Primary">
    <a href="/"              class:list={[linkBase, onHome         ? linkActive : linkInactive]}>Hub</a>
    <span class={sep} aria-hidden="true">·</span>
    <a href="/scroll/story/baseline" class:list={[linkBase, onStory        ? linkActive : linkInactive]}>Story</a>
    <span class={sep} aria-hidden="true">·</span>

    {scrollCycle && (
      <>
        <span
          class="inline-flex items-center gap-1 rounded-full border border-slate-200 dark:border-stone-50/20 vibrant:border-orange-500/40 bg-white/80 dark:bg-indigo-950/80 vibrant:bg-black/80 backdrop-blur-sm pl-1 pr-1 py-0.5"
          aria-label="Switch story variant"
        >
          <a
            href={scrollCycle.prev}
            aria-label="Previous story variant"
            class={arrowBtn}
          >‹</a>
          <span class="text-[10px] tracking-[0.2em] tabular-nums text-indigo-950 dark:text-stone-50 vibrant:text-orange-500 whitespace-nowrap px-2">
            {scrollCycle.current.label}
            <span class="text-slate-400 dark:text-slate-500 vibrant:text-cyan-300/60 normal-case ml-1.5">({scrollCycle.index}/{scrollCycle.total})</span>
          </span>
          <a
            href={scrollCycle.next}
            aria-label="Next story variant"
            class={arrowBtn}
          >›</a>
        </span>
        <span class={sep} aria-hidden="true">·</span>
      </>
    )}

    <a href="/strategies" class:list={[linkBase, onStrategies ? linkActive : linkInactive]}>Strategies</a>
    <span class={sep} aria-hidden="true">·</span>
    <a href="/scroll/automation/pipeline" class:list={[linkBase, onAutomation   ? linkActive : linkInactive]}>Automation</a>
  </nav>

  <div class="justify-self-end flex items-center gap-2">
    <div class="relative">
      <button
        type="button"
        id="utility-toggle"
        aria-haspopup="true"
        aria-expanded="false"
        aria-label="More — Brand Kit, Design System, Changelog"
        class:list={[
          'inline-flex h-7 w-7 items-center justify-center rounded-full transition-colors hover:bg-slate-100 dark:hover:bg-stone-50/10 vibrant:hover:bg-orange-500/15',
          (onBrandKit || onDesignSystem || onChangelog)
            ? 'text-indigo-950 dark:text-stone-50 vibrant:text-orange-500'
            : 'text-slate-500 dark:text-slate-400 vibrant:text-cyan-300 hover:text-indigo-950 dark:hover:text-stone-50 vibrant:hover:text-orange-500',
        ]}
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="9" />
          <path d="M8 14s1.5 2 4 2 4-2 4-2" />
          <line x1="9" y1="9.2" x2="9.01" y2="9.2" />
          <line x1="15" y1="9.2" x2="15.01" y2="9.2" />
        </svg>
      </button>

      <div
        id="utility-dropdown"
        hidden
        class="absolute right-0 mt-2 z-50 min-w-[10.5rem] rounded-md border border-slate-200 dark:border-stone-50/15 vibrant:border-orange-500/40 bg-white dark:bg-indigo-950 vibrant:bg-black shadow-lg py-1"
      >
        <a href="/brand-kit"     class:list={['block px-4 py-2 text-[10px] tracking-[0.2em] uppercase no-underline transition-colors hover:bg-slate-100 dark:hover:bg-stone-50/10 vibrant:hover:bg-orange-500/15', onBrandKit     ? linkActive : linkInactive]}>Brand Kit</a>
        <a href="/design-system" class:list={['block px-4 py-2 text-[10px] tracking-[0.2em] uppercase no-underline transition-colors hover:bg-slate-100 dark:hover:bg-stone-50/10 vibrant:hover:bg-orange-500/15', onDesignSystem ? linkActive : linkInactive]}>Design System</a>
        <a href="/changelog"     class:list={['block px-4 py-2 text-[10px] tracking-[0.2em] uppercase no-underline transition-colors hover:bg-slate-100 dark:hover:bg-stone-50/10 vibrant:hover:bg-orange-500/15', onChangelog    ? linkActive : linkInactive]}>Changelog</a>
      </div>
    </div>

    <ModeToggle />
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.getElementById('utility-toggle');
    var menu = document.getElementById('utility-dropdown');
    if (!toggle || !menu) return;
    function close() { menu.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
    toggle.addEventListener('click', function (e) {
      e.stopPropagation();
      var willOpen = menu.hidden;
      menu.hidden = !willOpen;
      toggle.setAttribute('aria-expanded', String(willOpen));
    });
    document.addEventListener('click', function (e) {
      if (!menu.hidden && !menu.contains(e.target) && !toggle.contains(e.target)) close();
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
  })();
</script>
