</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 60%, var(--color-background));
    padding: 2.5rem 1.5rem 1.5rem;
    margin-top: auto;
  }
  .site-footer__inner {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: start;
    gap: 2rem;
  }
  .site-footer__col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color 150ms ease, transform 200ms ease;
  }
  .site-footer__col:hover {
    color: var(--color-text);
    transform: translateY(-1px);
  }
  .site-footer__col--left { align-items: flex-start; }
  .site-footer__col--right { align-items: flex-end; }

  .site-footer__label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }
  .site-footer__heart {
    color: var(--color-accent);
    font-size: 0.85em;
    margin: 0 0.1em;
  }
  .site-footer__times {
    color: var(--color-accent);
    margin: 0 0.25em;
  }

  .site-footer__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Reach: three images, only one shown per mode (dark + vibrant share white). */
  .site-footer__img {
    height: 36px;
    width: auto;
    display: none;
  }
  :global([data-mode="light"])   .site-footer__img--mode-light   { display: inline-block; }
  :global([data-mode="dark"])    .site-footer__img--mode-dark    { display: inline-block; }
  :global([data-mode="vibrant"]) .site-footer__img--mode-vibrant { display: inline-block; }

  /* Lossless Group inlined SVG: tint the wordmark per mode.
     Icon and gradient stay fixed; only the dark-on-light text glyphs change. */
  .site-footer__mark--lossless svg {
    height: 28px;
    width: auto;
    display: block;
  }
  .lg-wordmark path { fill: var(--color-text); }

