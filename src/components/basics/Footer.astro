    <a class="site-footer__col site-footer__col--left"
       href="https://reach.edu"
       target="_blank"
       rel="noopener noreferrer">
      <span class="site-footer__label">Built for</span>
      <span class="site-footer__mark site-footer__mark--reach">
        <img class="site-footer__img site-footer__img--mode-light"
             src="/reach-logo.svg"
             alt="Reach University" />
        <img class="site-footer__img site-footer__img--mode-dark"
             src="/reach-logo-white.svg"
             alt="Reach University" />
        <img class="site-footer__img site-footer__img--mode-vibrant"
             src="/reach-logo-white.svg"
             alt="Reach University" />
      </span>
    </a>

