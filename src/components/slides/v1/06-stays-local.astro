---
/**
 * Play-UI 06 · Stays Local — recreated from T06-StaysLocal.astro
 */
import '../../../styles/global.css';
import '../../../styles/theme.css';
import '../../../styles/play-primitives.css';

const paths = [
  {
    label: "Recruit from away",
    tone: "var(--color-text-muted, #5c5578)",
    verb: "Leaks",
    points: [
      "Outsiders rarely stick — turnover resets the shortage.",
      "When they leave, their earnings leave with them.",
      "No compounding: the community keeps paying to re-recruit.",
    ],
  },
  {
    label: "Grow your own",
    tone: "var(--color-secondary, #218099)",
    verb: "Stays",
    points: [
      "The classroom is the campus — no one has to move.",
      "Credential and raise both land in the same community.",
      "Wages recirculate locally as a place-based multiplier.",
    ],
  },
];
---
<div class="play-canvas">
<section class="play-section" data-slot="06" data-variant="v1">
  <span class="play-kicker">06 / 11</span>

  <div>
    <p class="play-eyebrow" style="margin: 0 0 12px;">Where the money goes</p>
    <h2 class="play-h2">Grow-your-own keeps the talent — <span class="play-gradient">and the wages</span> — local.</h2>
  </div>

  <div class="play-grid" style="grid-template-columns: repeat(2, 1fr); margin-top: 8px;">
    {paths.map((p) => (
      <div class="play-card" style="display: flex; flex-direction: column; gap: 14px;">
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
          <span class="play-stat-label" style="color: var(--color-text, #1f1646); font-size: 18px;">{p.label}</span>
          <span class="play-chip" style="color: var(--color-text, #1f1646); border-color: var(--color-border, #e5e0dc);">{p.verb}</span>
        </div>
        <div class="play-rule"></div>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px;">
          {p.points.map((pt) => (
            <li style={`color: var(--color-text-muted, #5c5578); font-size: 17px; line-height: 1.5; border-left: 3px solid ${p.tone}; padding-left: 14px;`}>{pt}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
</div>
