---
/**
 * Play-UI 01 · Cover — recreated from src/layouts/sections/rural-income/T01-Cover.astro
 */
import '../../../styles/global.css';
import '../../../styles/theme.css';
import '../../../styles/play-primitives.css';
---
<div class="play-canvas">
<section class="play-section play-glow" data-slot="01" data-variant="v1" style="justify-content: space-between;">
  <header style="display: flex; align-items: baseline; justify-content: space-between; gap: 24px;">
    <span class="play-eyebrow">Reach × Lossless · Strategy</span>
    <span class="play-eyebrow" style="color: var(--color-text-muted, #5c5578);">Rural Prosperity · Draft</span>
  </header>

  <div style="max-width: 1200px;">
    <p class="play-eyebrow" style="color: var(--color-secondary, #218099); margin: 0 0 20px;">An apprenticeship-degree strategy</p>
    <h1 class="play-h1">
      Rural income boosts through <span class="play-gradient">Apprenticeship Degrees</span>.
    </h1>
    <p class="play-lede" style="margin-top: 28px;">
      Not a staffing patch — a place-based income engine. Start with a paid job,
      end with a better one: debt-free, in place, and the raise stays local.
    </p>
  </div>

  <footer style="display: flex; align-items: flex-end; justify-content: space-between; gap: 24px;">
    <div class="play-accent-bar"></div>
    <span class="play-eyebrow" style="color: var(--color-text-muted, #5c5578);">Reach University × The Lossless Group</span>
  </footer>
</section>
</div>
