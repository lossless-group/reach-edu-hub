# Site Configuration
PUBLIC_SITE_URL=https://reach-edu-hub.vercel.app

# Feature Flags (comma-separated)
# FEATURE_FLAGS=search,blog

# Brand Configuration
# PUBLIC_BRAND=reach

# Site Gate (src/middleware.ts + src/lib/gate.ts) — NOT PUBLIC_*, server-only.
# Either grants access: a shared passcode, or any email ending in the domain.
# Set real values in your local .env (gitignored) and in Vercel's env panel —
# never commit the actual passcode here.
RUH_GATE_PASSCODE=change-me
RUH_ALLOWED_EMAIL_DOMAIN=example.edu
